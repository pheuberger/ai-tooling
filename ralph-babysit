#!/usr/bin/env bash
# ralph-babysit — Autonomous PR shepherd: fixes review comments,
# diagnoses CI failures, pushes to production
#
# Polls unresolved PR review threads and failing CI checks, triages them,
# implements fixes, defers out-of-scope work to Linear, and notifies via
# Slack/Telegram. Fire-and-forget: run in background and it handles everything.
#
# Usage: ./ralph-babysit [options]
#   --pr NUMBER          PR number (default: detect from current branch)
#   --repo OWNER/REPO    GitHub repo (default: detect from git remote)
#   --interval SECONDS   Polling interval (default: 300)
#   --max-cycles N       Max polling cycles, 0 = infinite (default: 0)
#   --model MODEL        Force all agents to this model
#   --once               Single cycle, then exit
#   --test-cmd CMD       Run CMD as pre-commit test gate; retries worker on failure
#   --dry-run            Triage only, no fixes or pushes
#   -h, --help           Show this help
#
# Configuration (.ralphrc):
#   BABYSIT_INTERVAL, BABYSIT_MAX_CYCLES, BABYSIT_MAX_RETRIES,
#   BABYSIT_LINEAR_TEAM, BABYSIT_TEST_CMD, TRIAGE_MODEL,
#   BABYSIT_WORKER_MODEL, BABYSIT_COMMIT_MODEL, BABYSIT_CI_MODEL,
#   DEFER_MODEL, BABYSIT_MAX_CI_CYCLES, BABYSIT_CI_TIMEOUT,
#   NOTIFY_TELEGRAM_TOKEN, NOTIFY_TELEGRAM_CHAT_ID, NOTIFY_SLACK_WEBHOOK
#
# Requires: claude (Claude Code CLI), gh (GitHub CLI), jq, git

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROMPTS_DIR="${PROMPTS_DIR:-$SCRIPT_DIR/prompts}"

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------
C_RESET='\033[0m'
C_BOLD='\033[1m'
C_DIM='\033[2m'
C_CYAN='\033[36m'
C_GREEN='\033[32m'
C_YELLOW='\033[33m'
C_MAGENTA='\033[35m'
C_BLUE='\033[34m'
C_RED='\033[31m'
C_WHITE='\033[97m'

# ---------------------------------------------------------------------------
# Output helpers — clean, scannable terminal output
# ---------------------------------------------------------------------------
ts()         { printf '%s' "$(date '+%Y-%m-%d %H:%M:%S')"; }
log_ts()     { echo -e "${C_DIM}[$(ts)]${C_RESET} $*"; }
out()        { echo -e "  $1 $2"; }
detail()     { echo -e "    ${C_DIM}$1${C_RESET}"; }
section()    { echo -e "\n${C_BOLD}$1${C_RESET}"; }
phase_hdr()  { echo -e "  ${1}●${C_RESET} ${C_BOLD}${2}${C_RESET}"; }

fmt_duration() {
  local secs=$((${1:-0} / 1000))
  if [[ $secs -ge 60 ]]; then printf '%dm %ds' "$((secs/60))" "$((secs%60))"
  else printf '%ds' "$secs"; fi
}
fmt_cost() { printf '%.2f' "${1:-0}"; }

# render_prompt <template_file> [VAR1 VAR2 ...]
render_prompt() {
  local template="$1"; shift
  [[ -f "$template" ]] || { echo "Missing prompt template: $template" >&2; return 1; }

  local content
  content=$(<"$template")

  while [[ "$content" =~ \{\{#IF\ ([A-Z_]+)\}\} ]]; do
    local var_name="${BASH_REMATCH[1]}"
    local var_val="${!var_name:-}"
    if [[ -n "$var_val" ]]; then
      content=$(echo "$content" | sed "/{{#IF ${var_name}}}/d; /{{\/IF ${var_name}}}/d")
    else
      content=$(echo "$content" | sed "/{{#IF ${var_name}}}/,/{{\/IF ${var_name}}}/d")
    fi
  done

  local varlist=""
  for v in "$@"; do varlist="$varlist \${$v}"; done
  echo "$content" | envsubst "$varlist"
}

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
PR_NUMBER=""
REPO_FULL=""              # OWNER/REPO
INTERVAL=300              # seconds between cycles
MAX_CYCLES=0              # 0 = infinite
MAX_RETRIES=3             # retries per fix group
MODEL=""                  # global override
TRIAGE_MODEL=""           # triage agent — default: opus
BABYSIT_WORKER_MODEL=""   # fix worker — default: sonnet
BABYSIT_COMMIT_MODEL=""   # commit agent — default: haiku
BABYSIT_CI_MODEL=""       # CI fix worker — default: sonnet
DEFER_MODEL=""            # defer agent (Linear issue) — default: sonnet
DRY_RUN=false
ONCE=false
LINEAR_TEAM=""            # Linear team for deferred issues
LOG_DIR=".ralph-logs/babysit"
RALPH_RULES_FILE=".ralph-rules.md"
MAX_CI_CYCLES=3           # max rounds of CI fix attempts
CI_TIMEOUT=600            # seconds to wait for checks to complete
TEST_CMD=""               # --test-cmd: command to run as pre-commit test gate

# Notifications
NOTIFY_TELEGRAM_TOKEN=""
NOTIFY_TELEGRAM_CHAT_ID=""
NOTIFY_SLACK_WEBHOOK=""

# Source per-project config (CLI flags override)
if [[ -f ".ralphrc" ]]; then
  # shellcheck source=/dev/null
  source ".ralphrc"
fi

# Map .ralphrc convenience names (BABYSIT_* preferred, PR_WATCH_* fallback)
INTERVAL="${BABYSIT_INTERVAL:-${PR_WATCH_INTERVAL:-$INTERVAL}}"
MAX_CYCLES="${BABYSIT_MAX_CYCLES:-${PR_WATCH_MAX_CYCLES:-$MAX_CYCLES}}"
MAX_RETRIES="${BABYSIT_MAX_RETRIES:-${PR_WATCH_MAX_RETRIES:-$MAX_RETRIES}}"
LINEAR_TEAM="${BABYSIT_LINEAR_TEAM:-${PR_WATCH_LINEAR_TEAM:-$LINEAR_TEAM}}"
MAX_CI_CYCLES="${BABYSIT_MAX_CI_CYCLES:-$MAX_CI_CYCLES}"
CI_TIMEOUT="${BABYSIT_CI_TIMEOUT:-$CI_TIMEOUT}"
TEST_CMD="${BABYSIT_TEST_CMD:-$TEST_CMD}"

while [[ $# -gt 0 ]]; do
  case $1 in
    --pr)           PR_NUMBER="$2"; shift 2 ;;
    --repo)         REPO_FULL="$2"; shift 2 ;;
    --interval)     INTERVAL="$2"; shift 2 ;;
    --max-cycles)   MAX_CYCLES="$2"; shift 2 ;;
    --model)        MODEL="$2"; shift 2 ;;
    --test-cmd)     TEST_CMD="$2"; shift 2 ;;
    --once)         ONCE=true; MAX_CYCLES=1; shift ;;
    --dry-run)      DRY_RUN=true; shift ;;
    -h|--help)      sed -n '/^# Usage/,/^$/p' "$0" | sed 's/^# \?//'; exit 0 ;;
    *)              echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# ---------------------------------------------------------------------------
# Preflight
# ---------------------------------------------------------------------------
for cmd in claude gh jq git envsubst; do
  command -v "$cmd" >/dev/null 2>&1 || { echo "Required: $cmd" >&2; exit 1; }
done

# Detect PR number from current branch
if [[ -z "$PR_NUMBER" ]]; then
  PR_NUMBER=$(gh pr view --json number -q '.number' 2>/dev/null) \
    || { echo "No PR found for current branch. Use --pr NUMBER." >&2; exit 1; }
fi

# Detect repo from git remote
if [[ -z "$REPO_FULL" ]]; then
  REPO_FULL=$(gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null) \
    || { echo "Cannot detect repo. Use --repo OWNER/REPO." >&2; exit 1; }
fi

OWNER="${REPO_FULL%%/*}"
REPO="${REPO_FULL##*/}"

# Fetch PR metadata
PR_JSON=$(gh pr view "$PR_NUMBER" --json title,url,headRefName,baseRefName 2>/dev/null) \
  || { echo "Cannot fetch PR #$PR_NUMBER" >&2; exit 1; }
PR_TITLE=$(echo "$PR_JSON" | jq -r '.title')
PR_URL=$(echo "$PR_JSON" | jq -r '.url')
PR_HEAD=$(echo "$PR_JSON" | jq -r '.headRefName')
PR_BASE=$(echo "$PR_JSON" | jq -r '.baseRefName')

# Validate current branch matches PR head
current_branch=$(git rev-parse --abbrev-ref HEAD)
if [[ "$current_branch" != "$PR_HEAD" ]]; then
  echo "Current branch ($current_branch) does not match PR head ($PR_HEAD)." >&2
  echo "Checkout the PR branch first: git checkout $PR_HEAD" >&2
  exit 1
fi

# Per-agent model defaults (BABYSIT_* preferred, PR_WATCH_* fallback)
TRIAGE_MODEL="${MODEL:-${TRIAGE_MODEL:-claude-opus-4-6}}"
BABYSIT_WORKER_MODEL="${MODEL:-${BABYSIT_WORKER_MODEL:-${BABYSIT_WORKER_MODEL:-claude-sonnet-4-6}}}"
BABYSIT_COMMIT_MODEL="${MODEL:-${BABYSIT_COMMIT_MODEL:-${BABYSIT_COMMIT_MODEL:-claude-haiku-4-5-20251001}}}"
BABYSIT_CI_MODEL="${MODEL:-${BABYSIT_CI_MODEL:-claude-sonnet-4-6}}"
DEFER_MODEL="${MODEL:-${DEFER_MODEL:-claude-sonnet-4-6}}"

# Common claude flags
claude_flags=(--print --dangerously-skip-permissions)

claude_as() {
  local model="$1"; shift
  claude "${claude_flags[@]}" --model "$model" "$@"
}

short_model() { echo "$1" | sed 's/^claude-//; s/-[0-9].*//'; }

# Setup logging
mkdir -p "$LOG_DIR"
PROCESSED_FILE="$LOG_DIR/.processed-comments"
: > "$PROCESSED_FILE"  # reset each run — only skip threads within a single session

# Load project rules
project_rules=""
[[ -f "$RALPH_RULES_FILE" ]] && project_rules=$(<"$RALPH_RULES_FILE")

# Cost tracking
declare -A AGENT_COSTS
extract_cost() {
  local agent_type="$1" log_file="$2"
  local cost
  cost=$(jq -r 'select(.type == "result") | .total_cost_usd // 0' "$log_file" 2>/dev/null | tail -1)
  if [[ -n "$cost" && "$cost" != "0" && "$cost" != "null" ]]; then
    AGENT_COSTS[$agent_type]=$(echo "${AGENT_COSTS[$agent_type]:-0} + $cost" | bc 2>/dev/null || echo "${AGENT_COSTS[$agent_type]:-0}")
  fi
}

extract_result() {
  jq -r 'select(.type == "result") | "\(.duration_ms // 0) \(.total_cost_usd // 0)"' "$1" 2>/dev/null | tail -1
}

# Stream filter — same as ralph
ralph_stream_filter() {
  jq --unbuffered -r '
    if .type == "assistant" then
      [.message.content[]? |
        if .type == "tool_use" then
          (.input // {}) as $in |
          (.name as $n |
            if   $n == "Bash"   then $in.command // ""
            elif $n == "Edit"   then $in.file_path // ""
            elif $n == "Read"   then $in.file_path // ""
            elif $n == "Write"  then $in.file_path // ""
            elif $n == "Grep"   then ($in.pattern // "") + " " + ($in.path // "")
            elif $n == "Glob"   then $in.pattern // ""
            else "" end
          ) as $detail |
          "    \u001b[36m>>> " + .name + "\u001b[2m " + ($detail | .[0:120]) + "\u001b[0m"
        else empty end
      ] | join("\n") | select(length > 0)
    else empty end
  ' 2>/dev/null
}

# ---------------------------------------------------------------------------
# GraphQL helpers
# ---------------------------------------------------------------------------
GRAPHQL_QUERY_FILE=$(mktemp /tmp/ralph-babysit-threads.XXXXXX.graphql)
cat <<'GRAPHQL' > "$GRAPHQL_QUERY_FILE"
query($owner: String!, $repo: String!, $pr: Int!) {
  repository(owner: $owner, name: $repo) {
    pullRequest(number: $pr) {
      title
      url
      reviewThreads(first: 100) {
        nodes {
          id
          isResolved
          isOutdated
          comments(first: 20) {
            nodes {
              id
              body
              author { login }
              path
              line
              createdAt
              url
              reactionGroups {
                content
                users(first: 5) { nodes { login } }
              }
            }
          }
        }
      }
    }
  }
}
GRAPHQL

GRAPHQL_RESOLVE_FILE=$(mktemp /tmp/ralph-babysit-resolve.XXXXXX.graphql)
cat <<'GRAPHQL' > "$GRAPHQL_RESOLVE_FILE"
mutation($threadId: ID!) {
  resolveReviewThread(input: {threadId: $threadId}) {
    thread { isResolved }
  }
}
GRAPHQL

cleanup() {
  rm -f "$GRAPHQL_QUERY_FILE" "$GRAPHQL_RESOLVE_FILE"
  if [[ "${stashed:-false}" == true ]]; then
    git stash pop >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# Core functions
# ---------------------------------------------------------------------------

# Fetch unresolved comment threads, filtering out already-processed ones
fetch_unresolved_comments() {
  local raw_json
  raw_json=$(gh api graphql \
    -F owner="$OWNER" \
    -F repo="$REPO" \
    -F "pr=$PR_NUMBER" \
    -F query=@"$GRAPHQL_QUERY_FILE" 2>/dev/null) || { echo "[]"; return 1; }

  # Extract unresolved threads, filter out processed
  echo "$raw_json" | jq --slurpfile processed <(
    # Convert processed file to JSON array
    if [[ -s "$PROCESSED_FILE" ]]; then
      jq -R -s 'split("\n") | map(select(length > 0))' "$PROCESSED_FILE"
    else
      echo '[]'
    fi
  ) '
    [.data.repository.pullRequest.reviewThreads.nodes[] |
     select(.isResolved == false) |
     select(.id as $id | $processed[0] | index($id) | not)]
  '
}

# Check if a thread ID has been processed
is_processed() {
  grep -qxF "$1" "$PROCESSED_FILE" 2>/dev/null
}

# Mark a thread ID as processed
mark_processed() {
  echo "$1" >> "$PROCESSED_FILE"
}

# Reply to a review thread comment
reply_to_thread() {
  local comment_id="$1" body="$2"
  gh api "repos/$OWNER/$REPO/pulls/$PR_NUMBER/comments" \
    --method POST \
    -f body="$body" \
    -F "in_reply_to=$comment_id" > /dev/null 2>&1
}

# Resolve a review thread
resolve_thread() {
  local thread_id="$1"
  gh api graphql \
    -F query=@"$GRAPHQL_RESOLVE_FILE" \
    -f threadId="$thread_id" > /dev/null 2>&1
}

# Extract the numeric REST comment ID from a thread's first comment
# The GraphQL id is opaque; we need the numeric id for REST replies.
# We extract it from the comment URL: ...#discussion_r<ID> or from the
# databaseId field if present, or fall back to listing PR comments.
get_comment_id() {
  local thread_json="$1"
  local url
  url=$(echo "$thread_json" | jq -r '.comments.nodes[0].url // ""')
  if [[ "$url" =~ discussion_r([0-9]+) ]]; then
    echo "${BASH_REMATCH[1]}"
    return
  fi
  # Fallback: try databaseId from comments
  local db_id
  db_id=$(echo "$thread_json" | jq -r '.comments.nodes[0].id // ""')
  if [[ -n "$db_id" && "$db_id" =~ ^[0-9]+$ ]]; then
    echo "$db_id"
    return
  fi
  echo ""
}

# Triage all threads via Claude
triage_comments() {
  local threads_json="$1"
  local triage_log="$LOG_DIR/triage-$(date '+%Y%m%d-%H%M%S').log"

  phase_hdr "$C_BLUE" "Triage — $(short_model "$TRIAGE_MODEL")" >&2

  local triage_output
  triage_output=$(claude_as "$TRIAGE_MODEL" --output-format stream-json --verbose -p "$(
    export PR_NUMBER PR_TITLE PR_URL PR_BASE REPO_FULL
    export THREADS_JSON="$threads_json"
    render_prompt "$PROMPTS_DIR/babysit-triage.md" \
      PR_NUMBER PR_TITLE PR_URL PR_BASE REPO_FULL THREADS_JSON
  )" 2>&1 | tee "$triage_log" | ralph_stream_filter)

  extract_cost "triage" "$triage_log"
  read -r dur cost <<< "$(extract_result "$triage_log")"
  out "${C_GREEN}✓${C_RESET}" "${C_DIM}$(fmt_duration "$dur") · \$$(fmt_cost "$cost")${C_RESET}" >&2

  # Extract the JSON array from the assistant's text output
  # Use jq -s 'last' to handle cases where Claude outputs multiple JSON blocks
  jq -r 'select(.type == "assistant") | .message.content[]? | select(.type == "text") | .text' \
    "$triage_log" 2>/dev/null \
    | grep -v '^$' \
    | sed -n '/^\[/,/^\]/p' \
    | jq -s 'last' 2>/dev/null || echo "[]"
}

# Fix a group of comments
fix_comment_group() {
  local group_json="$1"
  local group_id
  group_id=$(echo "$group_json" | jq -r '.group_id')
  local fix_desc
  fix_desc=$(echo "$group_json" | jq -r '.fix_description')
  local threads_json
  threads_json=$(echo "$group_json" | jq -c '.threads')

  local retries=0
  local success=false

  # Build prompt file so test failures can be appended for retries
  local prompt_file
  prompt_file=$(mktemp /tmp/ralph-babysit-worker.XXXXXX.md)
  export PR_NUMBER PR_TITLE PR_BASE REPO_FULL
  export FIX_DESCRIPTION="$fix_desc" THREADS_JSON="$threads_json"
  export PROJECT_RULES="$project_rules"
  render_prompt "$PROMPTS_DIR/babysit-worker.md" \
    PR_NUMBER PR_TITLE PR_BASE REPO_FULL FIX_DESCRIPTION THREADS_JSON PROJECT_RULES \
    > "$prompt_file"

  while [[ $retries -lt $MAX_RETRIES ]]; do
    echo ""
    if [[ $MAX_RETRIES -gt 1 ]]; then
      phase_hdr "$C_CYAN" "Worker [$group_id] (attempt $((retries + 1))/$MAX_RETRIES) — $(short_model "$BABYSIT_WORKER_MODEL")"
    else
      phase_hdr "$C_CYAN" "Worker [$group_id] — $(short_model "$BABYSIT_WORKER_MODEL")"
    fi

    local worker_log="$LOG_DIR/worker-${group_id}-$(date '+%H%M%S').log"
    claude_as "$BABYSIT_WORKER_MODEL" --output-format stream-json --verbose -p "$(cat "$prompt_file")" \
      2>&1 | tee "$worker_log" | ralph_stream_filter || true

    extract_cost "worker" "$worker_log"

    if jq -e 'select(.type == "result" and .subtype == "success")' "$worker_log" > /dev/null 2>&1; then
      read -r dur cost <<< "$(extract_result "$worker_log")"
      out "${C_GREEN}✓${C_RESET}" "${C_DIM}$(fmt_duration "$dur") · \$$(fmt_cost "$cost")${C_RESET}"

      # Check if worker actually applied a fix
      local worker_text
      worker_text=$(jq -r 'select(.type == "assistant") | .message.content[]? | select(.type == "text") | .text' "$worker_log" 2>/dev/null | tail -1)
      if [[ "$worker_text" == *"FIX_SKIPPED"* ]]; then
        out "${C_YELLOW}⏭${C_RESET}" "worker skipped fix for $group_id"
        rm -f "$prompt_file"
        return 1
      fi

      # --- Pre-commit test gate ---
      if [[ -n "$TEST_CMD" ]]; then
        echo ""
        phase_hdr "$C_CYAN" "Test gate"
        local test_gate_log="$LOG_DIR/test-${group_id}-${retries}.log"
        if eval "$TEST_CMD" > "$test_gate_log" 2>&1; then
          out "${C_GREEN}✓${C_RESET}" "passed"
        else
          out "${C_RED}✗${C_RESET}" "failed"
          retries=$((retries + 1))
          if [[ $retries -lt $MAX_RETRIES ]]; then
            local test_snippet
            test_snippet=$(tail -80 "$test_gate_log")
            cat >> "$prompt_file" <<TESTFAIL

## Test Failures (attempt $retries)

Your previous changes cause test/typecheck failures. You MUST fix these.

Command: $TEST_CMD
Output (last 80 lines):
\`\`\`
$test_snippet
\`\`\`
TESTFAIL
            out "${C_YELLOW}↻${C_RESET}" "retrying worker with test output..."
            sleep 2
            continue
          fi
          # Exhausted retries on test failure
          rm -f "$prompt_file"
          return 1
        fi
      fi

      success=true
      break
    fi

    retries=$((retries + 1))
    if [[ $retries -lt $MAX_RETRIES ]]; then
      out "${C_YELLOW}✗${C_RESET}" "failed, retrying in 5s..."
      sleep 5
    fi
  done

  rm -f "$prompt_file"

  if [[ "$success" == false ]]; then
    out "${C_RED}✗${C_RESET}" "fix failed after $MAX_RETRIES attempts — $group_id"
    return 1
  fi
  return 0
}

# Commit changes locally (no push)
commit_changes() {
  local group_id="$1"

  # Check for actual changes
  if git diff --quiet && git diff --cached --quiet && \
     [[ -z "$(git ls-files --others --exclude-standard -- ':!.ralph-logs' 2>/dev/null)" ]]; then
    detail "no changes to commit"
    return 1
  fi

  echo ""
  phase_hdr "$C_YELLOW" "Commit — $(short_model "$BABYSIT_COMMIT_MODEL")"
  local commit_log="$LOG_DIR/commit-${group_id}-$(date '+%H%M%S').log"
  claude_as "$BABYSIT_COMMIT_MODEL" -p "$(
    export PR_NUMBER
    render_prompt "$PROMPTS_DIR/babysit-commit.md" PR_NUMBER
  )" > "$commit_log" 2>&1 \
    && out "${C_GREEN}✓${C_RESET}" "committed" \
    || { out "${C_RED}✗${C_RESET}" "commit failed"; return 1; }

  extract_cost "commit" "$commit_log"
  return 0
}

# Push with rebase-retry on conflict
push_changes() {
  local push_retries=0
  while [[ $push_retries -lt 3 ]]; do
    if git push 2>/dev/null; then
      out "${C_GREEN}✓${C_RESET}" "pushed"
      return 0
    fi
    push_retries=$((push_retries + 1))
    detail "push conflict — pulling and retrying ($push_retries/3)"
    if ! git pull --rebase 2>/dev/null; then
      out "${C_RED}✗${C_RESET}" "rebase conflict on push — aborting"
      git rebase --abort 2>/dev/null || true
      notify "error" "Push failed — rebase conflict"
      return 1
    fi
  done

  out "${C_RED}✗${C_RESET}" "push failed after retries"
  return 1
}

# Create a Linear issue for deferred work
defer_comment_group() {
  local group_json="$1"
  local group_id
  group_id=$(echo "$group_json" | jq -r '.group_id')
  local reason
  reason=$(echo "$group_json" | jq -r '.reason')
  local threads_json
  threads_json=$(echo "$group_json" | jq -c '.threads')

  echo "" >&2
  phase_hdr "$C_MAGENTA" "Defer [$group_id] — $(short_model "$DEFER_MODEL")" >&2
  local defer_log="$LOG_DIR/defer-${group_id}-$(date '+%H%M%S').log"

  claude_as "$DEFER_MODEL" -p "$(
    export PR_NUMBER PR_TITLE PR_URL REPO_FULL GROUP_ID="$group_id" REASON="$reason"
    export THREADS_JSON="$threads_json" LINEAR_TEAM="$LINEAR_TEAM"
    export PARENT_ISSUE_ID="${PARENT_ISSUE_ID:-}"
    render_prompt "$PROMPTS_DIR/babysit-defer.md" \
      PR_NUMBER PR_TITLE PR_URL REPO_FULL GROUP_ID REASON THREADS_JSON LINEAR_TEAM PARENT_ISSUE_ID
  )" > "$defer_log" 2>&1

  extract_cost "defer" "$defer_log"

  # Extract issue ID from output
  local issue_id
  issue_id=$(grep -oP 'ISSUE_ID:\s*\K\S+' "$defer_log" | tail -1 | tr -d '`')
  if [[ -n "$issue_id" ]]; then
    out "${C_GREEN}✓${C_RESET}" "created $issue_id" >&2
    echo "$issue_id"
  else
    out "${C_YELLOW}?${C_RESET}" "defer agent ran but no issue ID found" >&2
    echo ""
  fi
}

# ---------------------------------------------------------------------------
# CI check helpers
# ---------------------------------------------------------------------------

# Wait for all PR checks to reach a terminal state (or timeout)
wait_for_checks() {
  local timeout="$CI_TIMEOUT"
  local elapsed=0
  local interval=30
  while [[ $elapsed -lt $timeout ]]; do
    local pending
    pending=$(gh pr view "$PR_NUMBER" --json statusCheckRollup --jq '
      [.statusCheckRollup[] | select(.status != "COMPLETED")] | length
    ' 2>/dev/null || echo "0")
    if [[ "$pending" -eq 0 ]]; then return 0; fi
    detail "waiting for $pending check(s)... (${elapsed}s/${timeout}s)"
    sleep "$interval"
    elapsed=$((elapsed + interval))
  done
  return 1  # timeout
}

# Fetch failing checks as JSON array
fetch_failing_checks() {
  gh pr view "$PR_NUMBER" --json statusCheckRollup --jq '
    [.statusCheckRollup[] |
     select(.conclusion == "FAILURE" or .conclusion == "failure") |
     {name: .name, detailsUrl: .detailsUrl, context: .context}]
  ' 2>/dev/null || echo "[]"
}

# Fetch logs for a failing check
fetch_check_logs() {
  local check_name="$1"
  local logs=""

  # Try check-run annotations (structured errors with file/line)
  local run_id
  run_id=$(gh api "repos/$OWNER/$REPO/commits/$(git rev-parse HEAD)/check-runs" \
    --jq ".check_runs[] | select(.name == \"$check_name\" and .conclusion == \"failure\") | .id" \
    2>/dev/null | head -1)

  if [[ -n "$run_id" ]]; then
    local annotations
    annotations=$(gh api "repos/$OWNER/$REPO/check-runs/$run_id/annotations" \
      --jq '.[] | "\(.path):\(.start_line) — \(.annotation_level): \(.message)"' 2>/dev/null || true)
    [[ -n "$annotations" ]] && logs="$annotations"
  fi

  # Also try gh run view for workflow run logs
  local workflow_run_id
  workflow_run_id=$(gh run list --branch "$PR_HEAD" --status failure --limit 1 \
    --json databaseId --jq '.[0].databaseId' 2>/dev/null || true)
  if [[ -n "$workflow_run_id" ]]; then
    local run_logs
    run_logs=$(gh run view "$workflow_run_id" --log-failed 2>/dev/null | tail -100 || true)
    if [[ -n "$run_logs" ]]; then
      [[ -n "$logs" ]] && logs="$logs"$'\n\n'"--- Workflow run logs ---"$'\n'
      logs="${logs}${run_logs}"
    fi
  fi

  echo "$logs"
}

# Fix a CI failure via Claude worker agent
fix_ci_failure() {
  local check_name="$1" ci_log="$2"
  local ci_log_file="$LOG_DIR/ci-worker-${check_name//[^a-zA-Z0-9_-]/_}-$(date '+%H%M%S').log"

  phase_hdr "$C_CYAN" "CI Worker [$check_name] — $(short_model "$BABYSIT_CI_MODEL")"

  claude_as "$BABYSIT_CI_MODEL" --output-format stream-json --verbose -p "$(
    export PR_NUMBER PR_TITLE PR_BASE REPO_FULL
    export CHECK_NAME="$check_name" CI_LOG="$ci_log"
    export PROJECT_RULES="$project_rules"
    render_prompt "$PROMPTS_DIR/babysit-ci-worker.md" \
      PR_NUMBER PR_TITLE PR_BASE REPO_FULL CHECK_NAME CI_LOG PROJECT_RULES
  )" 2>&1 | tee "$ci_log_file" | ralph_stream_filter || true

  extract_cost "ci-worker" "$ci_log_file"

  if jq -e 'select(.type == "result" and .subtype == "success")' "$ci_log_file" > /dev/null 2>&1; then
    read -r dur cost <<< "$(extract_result "$ci_log_file")"
    out "${C_GREEN}✓${C_RESET}" "${C_DIM}$(fmt_duration "$dur") · \$$(fmt_cost "$cost")${C_RESET}"

    local worker_text
    worker_text=$(jq -r 'select(.type == "assistant") | .message.content[]? | select(.type == "text") | .text' "$ci_log_file" 2>/dev/null | tail -1)
    if [[ "$worker_text" == *"FIX_SKIPPED"* ]]; then
      out "${C_YELLOW}⏭${C_RESET}" "ci worker skipped fix for $check_name"
      return 1
    fi
    return 0
  fi

  out "${C_RED}✗${C_RESET}" "ci worker failed for $check_name"
  return 1
}

# ---------------------------------------------------------------------------
# Notification helpers
# ---------------------------------------------------------------------------
notify() {
  local type="$1" message="$2"

  # Telegram
  if [[ -n "$NOTIFY_TELEGRAM_TOKEN" && -n "$NOTIFY_TELEGRAM_CHAT_ID" ]]; then
    curl -s -X POST \
      "https://api.telegram.org/bot${NOTIFY_TELEGRAM_TOKEN}/sendMessage" \
      -d chat_id="$NOTIFY_TELEGRAM_CHAT_ID" \
      -d text="[$type] PR #$PR_NUMBER: $message" \
      -d parse_mode="Markdown" > /dev/null 2>&1 || true
  fi

  # Slack
  if [[ -n "$NOTIFY_SLACK_WEBHOOK" ]]; then
    local slack_text="[$type] <$PR_URL|PR #$PR_NUMBER> — $PR_TITLE: $message"
    local slack_resp
    slack_resp=$(curl -s -w "\n%{http_code}" -X POST "$NOTIFY_SLACK_WEBHOOK" \
      -H 'Content-type: application/json' \
      -d "{\"text\": $(echo "$slack_text" | jq -Rs .)}" 2>&1)
    local slack_http=${slack_resp##*$'\n'}
    if [[ "$slack_http" != "200" ]]; then
      detail "slack notify failed (HTTP $slack_http)"
    fi
  fi
}

send_cycle_summary() {
  local cycle="$1" fixed="$2" deferred="$3" questions="$4" dropped="$5" ci="${6:-}"

  # Build plain-text summary (used for Telegram + fallback)
  local summary="PR #$PR_NUMBER — Cycle $cycle"
  [[ -n "$fixed" ]]     && summary+="\n✅ Fixed:\n$fixed"
  [[ -n "$deferred" ]]  && summary+="\n↗️ Deferred:\n$deferred"
  [[ -n "$questions" ]] && summary+="\n❓ Needs attention:\n$questions"
  [[ -n "$dropped" ]]   && summary+="\n⊘ Dropped:\n$dropped"
  [[ -n "$ci" ]]        && summary+="\n🔧 CI:\n$ci"

  # Slack — mrkdwn sections
  if [[ -n "$NOTIFY_SLACK_WEBHOOK" ]]; then
    local blocks header_text
    header_text="*<$PR_URL|PR #$PR_NUMBER>* — Cycle $cycle"

    blocks=$(jq -n --arg hdr "$header_text" '[{"type":"section","text":{"type":"mrkdwn","text":$hdr}}]')

    if [[ -n "$fixed" ]]; then
      blocks=$(echo "$blocks" | jq --arg t "✅ *Fixed*\n$fixed" '. + [{"type":"section","text":{"type":"mrkdwn","text":$t}}]')
    fi
    if [[ -n "$deferred" ]]; then
      blocks=$(echo "$blocks" | jq --arg t "↗️ *Deferred*\n$deferred" '. + [{"type":"section","text":{"type":"mrkdwn","text":$t}}]')
    fi
    if [[ -n "$questions" ]]; then
      blocks=$(echo "$blocks" | jq --arg t "❓ *Needs attention*\n$questions" '. + [{"type":"section","text":{"type":"mrkdwn","text":$t}}]')
    fi
    if [[ -n "$dropped" ]]; then
      blocks=$(echo "$blocks" | jq --arg t "⊘ *Dropped*\n$dropped" '. + [{"type":"section","text":{"type":"mrkdwn","text":$t}}]')
    fi
    if [[ -n "$ci" ]]; then
      blocks=$(echo "$blocks" | jq --arg t "🔧 *CI*\n$ci" '. + [{"type":"section","text":{"type":"mrkdwn","text":$t}}]')
    fi

    local payload slack_resp slack_http
    payload=$(jq -n --argjson blocks "$blocks" --arg fallback "$(printf '%b' "$summary")" \
      '{blocks: $blocks, text: $fallback}')

    slack_resp=$(curl -s -w "\n%{http_code}" -X POST "$NOTIFY_SLACK_WEBHOOK" \
      -H 'Content-type: application/json' \
      -d "$payload" 2>&1)
    slack_http=${slack_resp##*$'\n'}
    if [[ "$slack_http" != "200" ]]; then
      detail "slack summary failed (HTTP $slack_http): ${slack_resp%$'\n'*}"
    fi
  fi

  # Telegram
  if [[ -n "$NOTIFY_TELEGRAM_TOKEN" && -n "$NOTIFY_TELEGRAM_CHAT_ID" ]]; then
    local tg_text
    tg_text=$(printf '%b' "$summary")
    curl -s -X POST \
      "https://api.telegram.org/bot${NOTIFY_TELEGRAM_TOKEN}/sendMessage" \
      -d chat_id="$NOTIFY_TELEGRAM_CHAT_ID" \
      -d text="$tg_text" \
      -d parse_mode="Markdown" > /dev/null 2>&1 || true
  fi
}

# Check if PR is mergeable (approved + 0 unresolved threads)
check_mergeable() {
  local pr_state
  pr_state=$(gh pr view "$PR_NUMBER" --json reviewDecision,reviewThreads 2>/dev/null) || return 1
  local decision
  decision=$(echo "$pr_state" | jq -r '.reviewDecision // ""')
  local unresolved
  unresolved=$(echo "$pr_state" | jq '[.reviewThreads[]? | select(.isResolved == false)] | length')
  [[ "$decision" == "APPROVED" && "$unresolved" -eq 0 ]]
}

# ---------------------------------------------------------------------------
# Display config
# ---------------------------------------------------------------------------
section "Babysit"
detail "PR #$PR_NUMBER — $PR_TITLE"
detail "repo: $REPO_FULL  branch: $PR_HEAD  base: $PR_BASE"
detail "interval: ${INTERVAL}s  max-cycles: ${MAX_CYCLES:-∞}  ci-cycles: $MAX_CI_CYCLES  ci-timeout: ${CI_TIMEOUT}s"
[[ -n "$TEST_CMD" ]]         && detail "test-cmd: $TEST_CMD"
[[ -f ".ralphrc" ]]          && detail ".ralphrc loaded"
[[ -f "$RALPH_RULES_FILE" ]] && detail "$RALPH_RULES_FILE loaded"
[[ "$DRY_RUN" == true ]]     && detail "DRY RUN — triage only, no fixes"
[[ "$ONCE" == true ]]        && detail "single cycle mode"
[[ -n "$LINEAR_TEAM" ]]      && detail "linear team: $LINEAR_TEAM"

if [[ -n "$MODEL" ]]; then
  detail "model (all): $(short_model "$MODEL")"
else
  detail "models: triage=$(short_model "$TRIAGE_MODEL")  worker=$(short_model "$BABYSIT_WORKER_MODEL")  commit=$(short_model "$BABYSIT_COMMIT_MODEL")  ci=$(short_model "$BABYSIT_CI_MODEL")  defer=$(short_model "$DEFER_MODEL")"
fi

has_notifications=false
[[ -n "$NOTIFY_SLACK_WEBHOOK" ]] && { detail "notify: slack"; has_notifications=true; }
[[ -n "$NOTIFY_TELEGRAM_TOKEN" && -n "$NOTIFY_TELEGRAM_CHAT_ID" ]] && { detail "notify: telegram"; has_notifications=true; }
[[ "$has_notifications" == false ]] && detail "notify: none configured"

# ---------------------------------------------------------------------------
# Stash any uncommitted changes so pulls don't conflict
# ---------------------------------------------------------------------------
stashed=false
if ! git diff --quiet HEAD 2>/dev/null || [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
  git stash push -u -m "ralph-babysit: auto-stash before run" >/dev/null 2>&1 && stashed=true
fi

# ---------------------------------------------------------------------------
# Main polling loop
# ---------------------------------------------------------------------------
cycle=0

while true; do
  cycle=$((cycle + 1))
  if [[ $MAX_CYCLES -gt 0 && $cycle -gt $MAX_CYCLES ]]; then
    section "${C_YELLOW}Reached max cycles ($MAX_CYCLES)${C_RESET}"
    break
  fi

  section "Cycle $cycle"

  # Pull latest changes
  log_ts "pulling latest..."
  if ! git pull --rebase 2>/dev/null; then
    out "${C_RED}✗${C_RESET}" "rebase conflict on pull"
    git rebase --abort 2>/dev/null || true
    notify "error" "Rebase conflict on pull — skipping cycle $cycle"
    if [[ $MAX_CYCLES -eq 1 ]]; then break; fi
    log_ts "sleeping ${INTERVAL}s..."
    sleep "$INTERVAL"
    continue
  fi

  # Fetch unresolved threads
  log_ts "fetching unresolved threads..."
  threads_json=$(fetch_unresolved_comments)
  thread_count=$(echo "$threads_json" | jq 'length')

  if [[ "$thread_count" -eq 0 ]]; then
    out "${C_GREEN}✓${C_RESET}" "no new unresolved threads"
  fi

  # Cycle summary accumulators (temp files to avoid subshell variable loss)
  sum_fixed=$(mktemp /tmp/ralph-bs-fixed.XXXXXX)
  sum_deferred=$(mktemp /tmp/ralph-bs-deferred.XXXXXX)
  sum_questions=$(mktemp /tmp/ralph-bs-questions.XXXXXX)
  sum_dropped=$(mktemp /tmp/ralph-bs-dropped.XXXXXX)

  # --- Review comment phase (skip if no threads) ---
  if [[ "$thread_count" -gt 0 ]]; then

  out "${C_CYAN}→${C_RESET}" "$thread_count unresolved thread(s) to triage"

  # Triage
  triage_json=$(triage_comments "$threads_json")
  group_count=$(echo "$triage_json" | jq 'length' 2>/dev/null || echo 0)

  if [[ "$group_count" -eq 0 ]]; then
    out "${C_YELLOW}?${C_RESET}" "triage returned no groups"
  fi

  if [[ "$group_count" -gt 0 ]]; then

  # --- Coverage check: ensure every input thread appears in triage output ---
  # Extract all thread IDs from input
  input_thread_ids=$(echo "$threads_json" | jq -r '.[].id')
  # Extract all thread IDs covered by triage groups
  covered_thread_ids=$(echo "$triage_json" | jq -r '.[].threads[]?.thread_id')

  uncovered_threads=""
  for tid in $input_thread_ids; do
    if ! echo "$covered_thread_ids" | grep -qxF "$tid"; then
      uncovered_threads+="$tid "
    fi
  done

  if [[ -n "${uncovered_threads% }" ]]; then
    uncovered_count=$(echo "$uncovered_threads" | wc -w)
    out "${C_YELLOW}!${C_RESET}" "$uncovered_count thread(s) missed by triage — adding as fix groups"

    for tid in $uncovered_threads; do
      # Reconstruct thread info from input JSON
      thread_data=$(echo "$threads_json" | jq -c --arg id "$tid" '.[] | select(.id == $id)')
      [[ -z "$thread_data" ]] && continue

      t_path=$(echo "$thread_data" | jq -r '.comments.nodes[0].path // ""')
      t_line=$(echo "$thread_data" | jq -r '.comments.nodes[0].line // 0')
      t_body=$(echo "$thread_data" | jq -r '.comments.nodes[0].body // "" | .[0:120]')
      t_cid=$(get_comment_id "$thread_data")

      triage_json=$(echo "$triage_json" | jq -c --arg tid "$tid" --arg cid "$t_cid" \
        --arg path "$t_path" --arg line "$t_line" --arg body "$t_body" \
        '. + [{
          "group_id": "fix-uncovered-\($tid | .[0:8])",
          "action": "fix",
          "threads": [{"thread_id": $tid, "comment_id": ($cid | tonumber? // 0), "path": $path, "line": ($line | tonumber? // 0), "summary": $body}],
          "fix_description": $body,
          "files": [$path],
          "reason": "Thread missed by triage — defaulting to fix (human reviewer benefit-of-the-doubt)"
        }]')
    done

    group_count=$(echo "$triage_json" | jq 'length')
  fi

  # Count by action
  fix_count=$(echo "$triage_json" | jq '[.[] | select(.action == "fix")] | length')
  defer_count=$(echo "$triage_json" | jq '[.[] | select(.action == "defer")] | length')
  question_count=$(echo "$triage_json" | jq '[.[] | select(.action == "question")] | length')
  drop_count=$(echo "$triage_json" | jq '[.[] | select(.action == "drop")] | length')

  detail "triage: $fix_count fix, $defer_count defer, $question_count question, $drop_count drop"

  # Show triage plan
  echo "$triage_json" | jq -r '.[] | "    \(.action): [\(.group_id)] \(.fix_description // .reason // "")"' 2>/dev/null

  if [[ "$DRY_RUN" == true ]]; then
    out "${C_YELLOW}⏭${C_RESET}" "dry run — skipping execution"
    echo "$triage_json" | jq '.'
  else

  # --- Process FIX groups (commit locally, push once at end) ---
  fix_groups=$(echo "$triage_json" | jq -c '[.[] | select(.action == "fix")]')
  fix_len=$(echo "$fix_groups" | jq 'length')
  pre_fix_sha=$(git rev-parse HEAD)
  all_fixes_passed=true
  committed_groups=()  # track groups that were successfully committed

  for i in $(seq 0 $((fix_len - 1))); do
    group=$(echo "$fix_groups" | jq -c ".[$i]")
    group_id=$(echo "$group" | jq -r '.group_id')
    fix_desc=$(echo "$group" | jq -r '.fix_description')
    files=$(echo "$group" | jq -r '.files | join(", ")')

    if fix_comment_group "$group"; then
      if commit_changes "$group_id"; then
        committed_groups+=("$i")
      fi
    else
      detail "fix failed for $group_id — aborting fix loop"
      all_fixes_passed=false
      break
    fi
  done

  # Push once if all fixes passed, or reset everything
  if [[ "$all_fixes_passed" == true && ${#committed_groups[@]} -gt 0 ]]; then
    echo ""
    phase_hdr "$C_GREEN" "Push (${#committed_groups[@]} fix commit(s))"
    if push_changes; then
      local_sha=$(git rev-parse --short HEAD)

      # Reply + resolve threads for all committed groups
      for ci_idx in "${committed_groups[@]}"; do
        group=$(echo "$fix_groups" | jq -c ".[$ci_idx]")
        group_id=$(echo "$group" | jq -r '.group_id')
        files=$(echo "$group" | jq -r '.files | join(", ")')

        thread_len=$(echo "$group" | jq '.threads | length')
        for ti in $(seq 0 $((thread_len - 1))); do
          thread=$(echo "$group" | jq -c ".threads[$ti]")
          tid=$(echo "$thread" | jq -r '.thread_id')
          cid=$(echo "$thread" | jq -r '.comment_id')
          reply_to_thread "$cid" "Fixed in $local_sha."
          resolve_thread "$tid"
          mark_processed "$tid"
        done
        out "${C_GREEN}✓${C_RESET}" "resolved $thread_len thread(s) for $group_id"

        first_cid=$(echo "$group" | jq -r '.threads[0].comment_id // ""')
        comment_link=""
        [[ -n "$first_cid" ]] && comment_link="${PR_URL}#discussion_r${first_cid}"

        if [[ -n "$comment_link" ]]; then
          echo "• <${comment_link}|\`$group_id\`> — $files" >> "$sum_fixed"
        else
          echo "• \`$group_id\` — $files" >> "$sum_fixed"
        fi
      done
    else
      out "${C_RED}✗${C_RESET}" "push failed — resetting local commits"
      git reset --hard "$pre_fix_sha" 2>/dev/null || true
      notify "error" "Push failed after fixes — all changes reverted"
    fi
  elif [[ "$all_fixes_passed" == false ]]; then
    if [[ "$(git rev-parse HEAD)" != "$pre_fix_sha" ]]; then
      out "${C_YELLOW}↩${C_RESET}" "fix failed — resetting ${#committed_groups[@]} local commit(s)"
      git reset --hard "$pre_fix_sha" 2>/dev/null || true
    fi
    notify "error" "Fix failed — no changes pushed"
  fi

  # --- Process DEFER groups ---
  defer_groups=$(echo "$triage_json" | jq -c '[.[] | select(.action == "defer")]')
  defer_len=$(echo "$defer_groups" | jq 'length')
  parent_issue_id=""

  # Strategy: 1 defer group → single issue, 2+ → parent + sub-issues
  if [[ "$defer_len" -gt 1 && -n "$LINEAR_TEAM" ]]; then
    echo ""
    phase_hdr "$C_MAGENTA" "Defer — creating parent issue ($defer_len sub-issues)"
    parent_log="$LOG_DIR/defer-parent-$(date '+%H%M%S').log"
    parent_issue_id=$(claude_as "$DEFER_MODEL" -p "Create a Linear issue using mcp__linear__save_issue with:
- title: \"Review feedback: PR #${PR_NUMBER} — ${PR_TITLE}\"
- description: \"Aggregated review feedback from ${PR_URL}. ${defer_len} item(s) deferred from this PR.\"
- team: \"${LINEAR_TEAM}\"
- priority: 3

Output the issue identifier on the last line, prefixed with ISSUE_ID:. Example: ISSUE_ID: ENG-456" 2>"$parent_log" \
      | grep -oP 'ISSUE_ID:\s*\K\S+' | tail -1 | tr -d '`') || true
    extract_cost "defer" "$parent_log"

    if [[ -n "$parent_issue_id" ]]; then
      out "${C_GREEN}✓${C_RESET}" "parent issue: $parent_issue_id"
    else
      out "${C_YELLOW}?${C_RESET}" "could not create parent issue — sub-issues will be standalone"
    fi
  fi

  for i in $(seq 0 $((defer_len - 1))); do
    group=$(echo "$defer_groups" | jq -c ".[$i]")
    group_id=$(echo "$group" | jq -r '.group_id')
    issue_id=$(PARENT_ISSUE_ID="$parent_issue_id" defer_comment_group "$group")

    thread_len=$(echo "$group" | jq '.threads | length')
    for ti in $(seq 0 $((thread_len - 1))); do
      thread=$(echo "$group" | jq -c ".threads[$ti]")
      tid=$(echo "$thread" | jq -r '.thread_id')
      cid=$(echo "$thread" | jq -r '.comment_id')
      if [[ -n "$issue_id" ]]; then
        reply_to_thread "$cid" "Valid point — tracked in $issue_id. Deferring from this PR to keep scope focused."
      else
        reply_to_thread "$cid" "Valid point — tracked for follow-up. Deferring from this PR to keep scope focused."
      fi
      mark_processed "$tid"
    done
    out "${C_CYAN}↗${C_RESET}" "deferred $group_id → ${issue_id:-no-issue}"

    first_cid=$(echo "$group" | jq -r '.threads[0].comment_id // ""')
    comment_link=""
    [[ -n "$first_cid" ]] && comment_link="${PR_URL}#discussion_r${first_cid}"
    issue_link=""
    [[ -n "$issue_id" ]] && issue_link="<https://linear.app/issue/${issue_id}|${issue_id}>"

    if [[ -n "$comment_link" ]]; then
      echo "• <${comment_link}|\`$group_id\`> → ${issue_link:-deferred}" >> "$sum_deferred"
    else
      echo "• \`$group_id\` → ${issue_link:-deferred}" >> "$sum_deferred"
    fi
  done

  # --- Process QUESTION groups ---
  q_groups=$(echo "$triage_json" | jq -c '[.[] | select(.action == "question")]')
  q_len=$(echo "$q_groups" | jq 'length')
  for i in $(seq 0 $((q_len - 1))); do
    group=$(echo "$q_groups" | jq -c ".[$i]")
    group_id=$(echo "$group" | jq -r '.group_id')
    answer=$(echo "$group" | jq -r '.answer // ""')
    reason=$(echo "$group" | jq -r '.reason')

    thread_len=$(echo "$group" | jq '.threads | length')
    for ti in $(seq 0 $((thread_len - 1))); do
      thread=$(echo "$group" | jq -c ".threads[$ti]")
      tid=$(echo "$thread" | jq -r '.thread_id')
      cid=$(echo "$thread" | jq -r '.comment_id')
      path=$(echo "$thread" | jq -r '.path // ""')
      line=$(echo "$thread" | jq -r '.line // ""')

      comment_permalink="${PR_URL}#discussion_r${cid}"
      if [[ -n "$answer" ]]; then
        reply_to_thread "$cid" "$answer"
        mark_processed "$tid"
        echo "• <${comment_permalink}|\`$path:$line\`> — answered" >> "$sum_questions"
        notify "question" "Answered: $path:$line — <${comment_permalink}|view comment>"
      else
        # Cannot answer — leave unresolved for next cycle, notify
        echo "• <${comment_permalink}|\`$path:$line\`> — ⚠️ needs human attention" >> "$sum_questions"
        notify "question" "⚠️ Needs human attention: $reason — $path:$line — <${comment_permalink}|view comment>"
      fi
    done
  done

  # --- Process DROP groups ---
  drop_groups=$(echo "$triage_json" | jq -c '[.[] | select(.action == "drop")]')
  drop_len=$(echo "$drop_groups" | jq 'length')
  for i in $(seq 0 $((drop_len - 1))); do
    group=$(echo "$drop_groups" | jq -c ".[$i]")
    group_id=$(echo "$group" | jq -r '.group_id')
    reason=$(echo "$group" | jq -r '.reason')

    thread_len=$(echo "$group" | jq '.threads | length')
    for ti in $(seq 0 $((thread_len - 1))); do
      thread=$(echo "$group" | jq -c ".threads[$ti]")
      tid=$(echo "$thread" | jq -r '.thread_id')
      cid=$(echo "$thread" | jq -r '.comment_id')
      reply_to_thread "$cid" "After review, $reason"
      mark_processed "$tid"
    done

    first_cid=$(echo "$group" | jq -r '.threads[0].comment_id // ""')
    if [[ -n "$first_cid" ]]; then
      echo "• <${PR_URL}#discussion_r${first_cid}|\`$group_id\`> — $reason" >> "$sum_dropped"
    else
      echo "• \`$group_id\` — $reason" >> "$sum_dropped"
    fi
  done

  fi # ! DRY_RUN
  fi # group_count > 0
  fi # thread_count > 0

  # --- CI Check Phase (skip in dry-run) ---
  if [[ "$DRY_RUN" != true ]]; then
  ci_cycle=0
  ci_fixed_total=0
  ci_unfixable=""
  sum_ci=$(mktemp /tmp/ralph-bs-ci.XXXXXX)

  while [[ $ci_cycle -lt $MAX_CI_CYCLES ]]; do
    ci_cycle=$((ci_cycle + 1))
    echo ""
    phase_hdr "$C_BLUE" "CI Checks (round $ci_cycle/$MAX_CI_CYCLES)"

    if ! wait_for_checks; then
      out "${C_YELLOW}⏱${C_RESET}" "timeout waiting for checks (${CI_TIMEOUT}s)"
      notify "ci" "Timed out waiting for CI checks to complete"
      break
    fi

    failing_checks=$(fetch_failing_checks)
    fail_count=$(echo "$failing_checks" | jq 'length')

    if [[ "$fail_count" -eq 0 ]]; then
      out "${C_GREEN}✓${C_RESET}" "all checks passing"
      break
    fi

    out "${C_RED}✗${C_RESET}" "$fail_count failing check(s)"
    ci_fixed_this_round=0

    for i in $(seq 0 $((fail_count - 1))); do
      check_name=$(echo "$failing_checks" | jq -r ".[$i].name")
      ci_log=$(fetch_check_logs "$check_name")

      if [[ -z "$ci_log" ]]; then
        detail "no logs available for $check_name — skipping"
        ci_unfixable+="• $check_name (no logs)\n"
        continue
      fi

      if fix_ci_failure "$check_name" "$ci_log"; then
        if commit_changes "ci-$check_name"; then
          ci_fixed_this_round=$((ci_fixed_this_round + 1))
          ci_fixed_total=$((ci_fixed_total + 1))
          echo "• \`$check_name\` — fixed" >> "$sum_ci"
        fi
      else
        out "${C_YELLOW}⏭${C_RESET}" "cannot fix $check_name"
        ci_unfixable+="• $check_name\n"
        echo "• \`$check_name\` — ⚠️ unfixable" >> "$sum_ci"
      fi
    done

    if [[ $ci_fixed_this_round -eq 0 ]]; then
      detail "no fixes applied this round — stopping CI loop"
      break
    fi

    # Push CI fixes so checks re-run
    echo ""
    phase_hdr "$C_GREEN" "Push ($ci_fixed_this_round CI fix commit(s))"
    if ! push_changes; then
      notify "error" "Push failed after CI fixes"
      break
    fi
    out "${C_GREEN}✓${C_RESET}" "fixed $ci_fixed_this_round check(s) this round"
  done

  # Notify about unfixable CI failures
  if [[ -n "$ci_unfixable" ]]; then
    notify "ci" "Unfixable CI failures:\n$ci_unfixable"
  fi
  fi # ! DRY_RUN (CI phase)

  # --- Cycle summary ---
  summary_fixed=$(cat "$sum_fixed" 2>/dev/null || true)
  summary_deferred=$(cat "$sum_deferred" 2>/dev/null || true)
  summary_questions=$(cat "$sum_questions" 2>/dev/null || true)
  summary_dropped=$(cat "$sum_dropped" 2>/dev/null || true)
  summary_ci=$(cat "${sum_ci:-/dev/null}" 2>/dev/null || true)
  rm -f "$sum_fixed" "$sum_deferred" "$sum_questions" "$sum_dropped" "${sum_ci:-}" 2>/dev/null || true

  if [[ -n "$summary_fixed" || -n "$summary_deferred" || -n "$summary_questions" || -n "$summary_dropped" || -n "$summary_ci" ]]; then
    send_cycle_summary "$cycle" "$summary_fixed" "$summary_deferred" "$summary_questions" "$summary_dropped" "$summary_ci"
  fi

  # Check mergeability after processing
  if check_mergeable; then
    section "${C_GREEN}PR is mergeable!${C_RESET}"
    notify "mergeable" "All threads resolved, PR is approved and mergeable."
    break
  fi

  if [[ $MAX_CYCLES -eq 1 ]]; then break; fi
  log_ts "sleeping ${INTERVAL}s..."
  sleep "$INTERVAL"
done

# ---------------------------------------------------------------------------
# Cost report
# ---------------------------------------------------------------------------
if [[ "${AGENT_COSTS[@]+x}" ]]; then
  section "Cost"
  total=0
  for agent_type in "${!AGENT_COSTS[@]}"; do
    cost="${AGENT_COSTS[$agent_type]}"
    printf "    %-20s \$%s\n" "$agent_type" "$(fmt_cost "$cost")"
    total=$(echo "$total + $cost" | bc 2>/dev/null || echo "$total")
  done
  printf "    ${C_BOLD}%-20s \$%s${C_RESET}\n" "total" "$(fmt_cost "$total")"
fi

section "Done — $cycle cycle(s)"
