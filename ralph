#!/usr/bin/env bash
# ralph — Ralph Loop for vima-driven autonomous coding
#
# Spawns a fresh Claude Code instance per ready ticket. Each instance gets
# clean context — no conversation history carries over. State lives in
# the filesystem and git, not in the LLM's memory. This sidesteps context
# degradation by treating every iteration as a brand-new session.
#
# Usage: ./ralph [options]
#   --max-iterations N   Maximum total iterations (default: 50)
#   --max-retries N      Retries per ticket on failure (default: 3)
#   --model MODEL        Force ALL agents to this model (overrides per-agent models)
#   --tickets ID[,ID,..] Only process these tickets, in order (skip vima ready)
#   --respect-deps       With --tickets: skip tickets whose dependencies aren't closed yet
#   --type TYPE          Filter ready tickets by type (feature|bug|task)
#   --priority N         Only pick tickets with priority <= N (0=critical … 4=backlog)
#   --owner NAME         Only pick tickets owned by NAME
#   --tag TAG            Filter ready tickets by tag
#   --from-plan FILE     Decompose a plan file into tag-grouped tasks, then work them
#   --test-cmd CMD       Run CMD as pre-commit test gate; retries worker on failure
#   --watchdog N         Kill worker after N minutes of inactivity (default: 15)
#   --no-watchdog        Disable the inactivity watchdog
#   --triage            Evaluate and refine open tickets before starting work.
#                        Auto-improves underspecified tickets, defers ones
#                        needing human input (tagged needs-input), then runs
#                        the worker loop on approved tickets only.
#   --triage-only        Like --triage, but stop after triage (no worker loop)
#   --review-only [REF]  Skip worker loop; run only final review + summary.
#                        REF is the git ref to diff from (default: empty tree)
#
# Configuration files (optional):
#   .ralphrc             Sourced from project root before CLI args are parsed.
#                        Set any of: MAX_ITERATIONS, MAX_RETRIES, MODEL,
#                        WORKER_MODEL, SIMPLIFY_MODEL, REVIEWER_MODEL,
#                        COMMIT_MODEL, FINAL_REVIEW_MODEL, LEAD_MODEL,
#                        SPEC_MODEL, SUMMARY_MODEL,
#                        FILTER_TYPE, FILTER_PRIORITY, FILTER_OWNER,
#                        FILTER_TAG, TEST_CMD, WATCHDOG_TIMEOUT,
#                        LOG_DIR, RALPH_RULES_FILE.
#                        TRIAGE_MODEL,
#                        CLI flags override values set here.
#   .ralph-rules.md      Extra instructions injected into the agent prompt as a
#                        "## Project Rules" section. Use for ralph-specific rules
#                        that don't belong in AGENTS.md or CLAUDE.md. Silently
#                        skipped if absent. Path configurable via RALPH_RULES_FILE.
#
# Requires: claude (Claude Code CLI), vima, jq, git
#
# References:
#   https://github.com/snarktank/ralph
#   https://medium.com/@tentenco/what-is-ralph-loop-a-new-era-of-autonomous-coding-96a4bb3e2ac8

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROMPTS_DIR="${PROMPTS_DIR:-$SCRIPT_DIR/prompts}"

# Colors
C_RESET='\033[0m'
C_BOLD='\033[1m'
C_DIM='\033[2m'
C_CYAN='\033[36m'
C_GREEN='\033[32m'
C_YELLOW='\033[33m'
C_MAGENTA='\033[35m'
C_BLUE='\033[34m'
C_RED='\033[31m'
C_WHITE='\033[97m'

ts()         { printf '%s' "$(date '+%Y-%m-%d %H:%M:%S')"; }
log_ts()     { echo -e "${C_DIM}[$(ts)]${C_RESET} $*"; }
ticket_field() { echo "$1" | jq -r ".$2 // \"$3\""; }
slugify()    { echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g; s/--*/-/g; s/^-//; s/-$//' | cut -c1-50; }

# Output helpers — clean, scannable terminal output
out()        { echo -e "  $1 $2"; }
detail()     { echo -e "    ${C_DIM}$1${C_RESET}"; }
section()    { echo -e "\n${C_BOLD}$1${C_RESET}"; }
phase_hdr()  { echo -e "  ${1}●${C_RESET} ${C_BOLD}${2}${C_RESET}"; }

fmt_duration() {
  local secs=$((${1:-0} / 1000))
  if [[ $secs -ge 60 ]]; then printf '%dm %ds' "$((secs/60))" "$((secs%60))"
  else printf '%ds' "$secs"; fi
}
fmt_cost() { printf '%.2f' "${1:-0}"; }

# render_prompt <template_file> [VAR1 VAR2 ...]
# Reads a markdown template, processes {{#IF VAR}}/{{/IF VAR}} conditionals,
# then runs envsubst with an explicit variable list. No eval — safe by design.
render_prompt() {
  local template="$1"; shift
  [[ -f "$template" ]] || { echo "Missing prompt template: $template" >&2; return 1; }

  local content
  content=$(<"$template")

  # Process {{#IF VAR}}...{{/IF VAR}} conditional blocks.
  # If the named env var is non-empty, keep the block contents; otherwise remove the block.
  while [[ "$content" =~ \{\{#IF\ ([A-Z_]+)\}\} ]]; do
    local var_name="${BASH_REMATCH[1]}"
    local var_val="${!var_name:-}"
    if [[ -n "$var_val" ]]; then
      # Keep block contents, remove markers
      content=$(echo "$content" | sed "/{{#IF ${var_name}}}/d; /{{\/IF ${var_name}}}/d")
    else
      # Remove entire block including markers
      content=$(echo "$content" | sed "/{{#IF ${var_name}}}/,/{{\/IF ${var_name}}}/d")
    fi
  done

  # Build envsubst variable list: $VAR1 $VAR2 ...
  local varlist=""
  for v in "$@"; do varlist="$varlist \${$v}"; done

  echo "$content" | envsubst "$varlist"
}

# True if there are unstaged, staged, or untracked changes outside .ralph-logs/ and .vima/
has_code_changes() {
  git diff --quiet -- ':!.ralph-logs' ':!.vima' 2>/dev/null            || return 0
  git diff --cached --quiet -- ':!.ralph-logs' ':!.vima' 2>/dev/null   || return 0
  [[ -z "$(git ls-files --others --exclude-standard -- ':!.ralph-logs' ':!.vima' 2>/dev/null)" ]] || return 0
  return 1
}

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
MAX_ITERATIONS=50
MAX_RETRIES=3
MODEL=""              # global override — forces all agents to this model
LEAD_MODEL=""         # lead agent (plan decomposition) — default: opus
SPEC_MODEL=""         # spec reviewer — default: opus
WORKER_MODEL=""       # coding worker — default: sonnet
COMMIT_MODEL=""       # commit agent — default: haiku
SIMPLIFY_MODEL=""     # post-worker code simplifier — default: sonnet
SIMPLIFY_THRESHOLD=10 # skip simplify when worker diff is fewer lines than this
REVIEWER_MODEL=""     # intermittent code reviewer — default: sonnet
FINAL_REVIEW_MODEL="" # final parallel review personas — default: opus
SUMMARY_MODEL=""      # post-run summary — default: haiku
TRIAGE_MODEL=""       # ticket triage/refinement — default: opus
TRIAGE=false          # --triage: evaluate and refine tickets before work
TRIAGE_ONLY=false     # --triage-only: stop after triage phase
TICKET_IDS=""         # comma-separated explicit ticket list (--tickets mode only)
PLAN_TAG=""           # tag slug generated from --from-plan title
EXPLICIT_MODE=false   # set when --tickets is used (prevents fallback to vima ready)
RESPECT_DEPS=false    # with --tickets: skip tickets whose deps aren't closed
FILTER_TYPE=""        # filter by type (feature|bug|task)
FILTER_PRIORITY=""    # only tickets with priority <= this value (0=critical … 4=backlog)
FILTER_OWNER=""       # only tickets owned by this name
FILTER_TAG=""         # filter by tag
PLAN_FILE=""          # --from-plan: plan file to decompose into tickets
TEST_CMD=""           # --test-cmd: command to run as pre-commit test gate
WATCHDOG_TIMEOUT=15  # minutes of worker inactivity before kill (0=disabled)
REVIEW_ONLY=false    # --review-only: skip loop, run final review + summary
REVIEW_ONLY_REF=""   # git ref to diff from (empty = empty tree)
LOG_DIR=".ralph-logs"
RALPH_RULES_FILE=".ralph-rules.md"

# Source per-project config (CLI flags override)
if [[ -f ".ralphrc" ]]; then
  # shellcheck source=/dev/null
  source ".ralphrc"
fi

SKIP_FILE="$LOG_DIR/.skipped"

while [[ $# -gt 0 ]]; do
  case $1 in
    --max-iterations) MAX_ITERATIONS="$2"; shift 2 ;;
    --max-retries)    MAX_RETRIES="$2"; shift 2 ;;
    --model)          MODEL="$2"; shift 2 ;;
    --tickets)        TICKET_IDS="$2"; EXPLICIT_MODE=true; shift 2 ;;
    --respect-deps)   RESPECT_DEPS=true; shift ;;
    --type)           FILTER_TYPE="$2"; shift 2 ;;
    --priority)       FILTER_PRIORITY="$2"; shift 2 ;;
    --owner)          FILTER_OWNER="$2"; shift 2 ;;
    --tag)            FILTER_TAG="$2"; shift 2 ;;
    --from-plan)      PLAN_FILE="$2"; shift 2 ;;
    --triage)         TRIAGE=true; shift ;;
    --triage-only)    TRIAGE=true; TRIAGE_ONLY=true; shift ;;
    --test-cmd)       TEST_CMD="$2"; shift 2 ;;
    --watchdog)       WATCHDOG_TIMEOUT="$2"; shift 2 ;;
    --no-watchdog)    WATCHDOG_TIMEOUT=0; shift ;;
    --review-only)    REVIEW_ONLY=true; shift
                      # Optional ref argument (skip if next arg looks like a flag or is absent)
                      if [[ $# -gt 0 && "$1" != -* ]]; then REVIEW_ONLY_REF="$1"; shift; fi ;;
    -h|--help)        sed -n '/^# Usage/,/^$/p' "$0" | sed 's/^# \?//'; exit 0 ;;
    *)                echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# Read plan file early — before untracked-file stashing moves it away
plan_title=""
plan_body=""
if [[ -n "$PLAN_FILE" ]]; then
  if [[ ! -f "$PLAN_FILE" ]]; then
    echo "Plan file not found: $PLAN_FILE" >&2; exit 1
  fi
  plan_title=$(head -1 "$PLAN_FILE" | sed 's/^#* *//')
  plan_body=$(tail -n +2 "$PLAN_FILE")
fi

# ---------------------------------------------------------------------------
# Preflight
# ---------------------------------------------------------------------------
for cmd in claude vima jq git envsubst; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Required: $cmd is not installed." >&2
    case "$cmd" in
      vima)   echo "  Install: cargo install --git https://github.com/pheuberger/vima --path vima-cli" >&2 ;;
      claude) echo "  Install: https://docs.anthropic.com/en/docs/claude-code" >&2 ;;
    esac
    exit 1
  fi
done

git diff --quiet --cached 2>/dev/null || { echo "Staged changes exist. Commit or stash first." >&2; exit 1; }

# Move pre-existing untracked files (PLAN.md, SPEC.md, etc.) out of the
# working tree so git add -A inside the loop doesn't pick them up.
# We can't use git stash because it would also revert unstaged tracked
# changes in .vima/, breaking vima ready.
STASH_DIR=""
untracked=$(git ls-files --others --exclude-standard -- ':!.vima' ':!.ralph-logs' 2>/dev/null)
if [[ -n "$untracked" ]]; then
  STASH_DIR=$(mktemp -d /tmp/ralph-stash.XXXXXX)
  echo "$untracked" | while IFS= read -r f; do
    mkdir -p "$STASH_DIR/$(dirname "$f")"
    mv "$f" "$STASH_DIR/$f"
  done
  log_ts "Shelved $(echo "$untracked" | wc -l | tr -d ' ') untracked file(s)"
fi

mkdir -p "$LOG_DIR"

# Warn if stale logs exist from a previous run
existing=()
for f in "$LOG_DIR"/iter-* "$LOG_DIR"/final-review-*; do
  [[ -f "$f" ]] && existing+=("$f")
done

if [[ ${#existing[@]} -gt 0 ]]; then
  log_ts "${C_YELLOW}Found ${#existing[@]} log file(s) from a previous run${C_RESET}"
  read -r -p "  Clear old logs before starting? [Y/n] " answer </dev/tty
  if [[ "${answer:-Y}" =~ ^[Yy]$ ]]; then
    rm -f "${existing[@]}"
    detail "cleared"
  else
    detail "keeping — summary will include prior run(s)"
  fi
fi

: > "$SKIP_FILE"

# Stream filter — extracts readable progress from stream-json output
ralph_stream_filter() {
  jq --unbuffered -r '
    if .type == "assistant" then
      [.message.content[]? |
        if .type == "tool_use" then
          (.input // {}) as $in |
          (.name as $n |
            if   $n == "Bash"   then $in.command // ""
            elif $n == "Edit"   then $in.file_path // ""
            elif $n == "Read"   then $in.file_path // ""
            elif $n == "Write"  then $in.file_path // ""
            elif $n == "Grep"   then ($in.pattern // "") + " " + ($in.path // "")
            elif $n == "Glob"   then $in.pattern // ""
            else "" end
          ) as $detail |
          "    \u001b[36m>>> " + .name + "\u001b[2m " + ($detail | .[0:120]) + "\u001b[0m"
        else empty end
      ] | join("\n") | select(length > 0)
    else empty end
  ' 2>/dev/null
}

# Extract titles of tickets filed via `vima create` in a review log
extract_filed_tickets() {
  jq -r 'select(.type == "assistant") | .message.content[]? | select(.type == "tool_use" and .name == "Bash") | .input.command // ""' "$1" 2>/dev/null \
    | grep -oP 'vima create "\K[^"]+' \
    | while IFS= read -r title; do detail "⎿ $title"; done
}

# Extract duration_ms and total_cost_usd from a stream-json log file
extract_result() {
  jq -r 'select(.type == "result") | "\(.duration_ms // 0) \(.total_cost_usd // 0)"' "$1" 2>/dev/null | tail -1
}

iteration=0

# Common claude flags — shared by all agent invocations
claude_flags=(--print --dangerously-skip-permissions)

# Per-agent model defaults — global MODEL overrides everything
LEAD_MODEL="${MODEL:-${LEAD_MODEL:-claude-opus-4-6}}"
SPEC_MODEL="${MODEL:-${SPEC_MODEL:-claude-opus-4-6}}"
WORKER_MODEL="${MODEL:-${WORKER_MODEL:-claude-sonnet-4-6}}"
COMMIT_MODEL="${MODEL:-${COMMIT_MODEL:-claude-haiku-4-5-20251001}}"
SIMPLIFY_MODEL="${MODEL:-${SIMPLIFY_MODEL:-claude-sonnet-4-6}}"
REVIEWER_MODEL="${MODEL:-${REVIEWER_MODEL:-claude-sonnet-4-6}}"
FINAL_REVIEW_MODEL="${MODEL:-${FINAL_REVIEW_MODEL:-claude-opus-4-6}}"
SUMMARY_MODEL="${MODEL:-${SUMMARY_MODEL:-claude-haiku-4-5-20251001}}"
TRIAGE_MODEL="${MODEL:-${TRIAGE_MODEL:-claude-opus-4-6}}"

# Run claude with a specific model: claude_as <model> [extra-args...]
# setsid -w detaches from controlling terminal so claude can't write
# alternate-screen / cursor-control sequences to /dev/tty (which destroys
# the caller's scrollback).  -w keeps the wrapper alive until claude exits.
# CI=true tells test runners (vitest, jest, etc.) to run non-interactively
# instead of entering watch mode, which would hang the agent indefinitely.
claude_as() {
  local model="$1"; shift
  CI=true setsid -w claude "${claude_flags[@]}" --model "$model" "$@"
}

# Watchdog — kills a background agent subshell if its log file goes stale.
# Runs in background; caller must kill it after the agent exits.
_watchdog() {
  local log_file="$1" timeout_min="$2" target_pid="$3"
  local timeout_sec=$((timeout_min * 60))
  local last_tool_count=0 last_change
  last_change=$(date +%s)
  while kill -0 "$target_pid" 2>/dev/null; do
    sleep 30
    [[ -f "$log_file" ]] || continue
    local current_tool_count now
    current_tool_count=$(grep -c '"tool_use"' "$log_file" 2>/dev/null | tail -1 || true)
    [[ "$current_tool_count" =~ ^[0-9]+$ ]] || current_tool_count=0
    if (( current_tool_count != last_tool_count )); then
      last_tool_count=$current_tool_count
      last_change=$(date +%s)
    fi
    now=$(date +%s)
    # If the result event is already in the log, the agent is done — give it
    # 60s to exit cleanly, then force-kill.
    if grep -q '"type":"result"' "$log_file" 2>/dev/null; then
      sleep 60
      if kill -0 "$target_pid" 2>/dev/null; then
        out "${C_RED}⏱${C_RESET}" "watchdog: agent finished but process hung — killing"
        pkill -TERM -P "$target_pid" 2>/dev/null || true
        sleep 2
        kill -TERM "$target_pid" 2>/dev/null || true
      fi
      return
    fi
    if (( now - last_change > timeout_sec )); then
      echo ""
      out "${C_RED}⏱${C_RESET}" "watchdog: no tool calls for ${timeout_min}m — killing agent"
      # Signal to run_agent that this was a watchdog kill (not a normal exit)
      touch "${log_file}.watchdog-killed"
      pkill -TERM -P "$target_pid" 2>/dev/null || true
      sleep 2
      kill -TERM "$target_pid" 2>/dev/null || true
      return
    fi
  done
}

# Sink for run_agent — discards console output (quiet agents)
_discard() { cat > /dev/null; }

# Heartbeat — prints elapsed time every 60s so the user knows the agent is alive.
# Only active when display_fn is ralph_stream_filter (visible agents).
_heartbeat() {
  local target_pid="$1" start=$SECONDS
  while kill -0 "$target_pid" 2>/dev/null; do
    sleep 60
    kill -0 "$target_pid" 2>/dev/null || break
    local elapsed=$(( SECONDS - start ))
    printf '    \033[2m⋯ %dm elapsed\033[0m\n' $((elapsed / 60))
  done
}

# run_agent <display_fn> <log_file> <model> [claude args...]
# Runs claude with tee streaming to log_file and optional watchdog.
# Console output is piped through display_fn (ralph_stream_filter or _discard).
run_agent() {
  local display="$1" log_file="$2" model="$3"; shift 3
  if (( WATCHDOG_TIMEOUT > 0 )); then
    > "$log_file"
    # Save stdin to fd 9 — background processes get stdin from /dev/null,
    # but some agents (worker) read their prompt from stdin.
    exec 9<&0
    (
      exec 0<&9 9<&-
      claude_as "$model" "$@" 2>&1 | tee "$log_file" | "$display"
    ) &
    local _pid=$! _wdpid _hbpid="" _rc=0
    exec 9<&-
    _watchdog "$log_file" "$WATCHDOG_TIMEOUT" "$_pid" &
    _wdpid=$!
    # Show heartbeat for visible agents so silence during thinking isn't alarming
    if [[ "$display" == ralph_stream_filter ]]; then
      _heartbeat "$_pid" &
      _hbpid=$!
    fi
    wait "$_pid" || _rc=$?
    kill "$_wdpid" 2>/dev/null; wait "$_wdpid" 2>/dev/null || true
    [[ -n "$_hbpid" ]] && { kill "$_hbpid" 2>/dev/null; wait "$_hbpid" 2>/dev/null || true; }
    # If the watchdog killed the agent, strip any result event claude may
    # have emitted during SIGTERM shutdown — callers check the log for
    # result/success to decide next steps, and a watchdog kill is never success.
    if [[ -f "${log_file}.watchdog-killed" ]]; then
      rm -f "${log_file}.watchdog-killed"
      sed -i '/"type":"result"/d' "$log_file" 2>/dev/null || true
      return 1
    fi
    return "$_rc"
  else
    claude_as "$model" "$@" 2>&1 | tee "$log_file" | "$display"
  fi
}

# Short model name for display: claude-sonnet-4-6 → sonnet
short_model() { echo "$1" | sed 's/^claude-//; s/-[0-9].*//'; }

section "Ralph Loop"
detail "iterations: $MAX_ITERATIONS  retries: $MAX_RETRIES"
cfg_opt() { [[ -n "${2:-}" ]] && detail "$1: $2" || true; }
[[ -f ".ralphrc" ]]          && detail ".ralphrc loaded"
[[ -f "$RALPH_RULES_FILE" ]] && detail "$RALPH_RULES_FILE loaded"
[[ "$TRIAGE" == true ]] && detail "triage: yes$( [[ "$TRIAGE_ONLY" == true ]] && echo ' (only)' )" || true
cfg_opt "plan"     "$PLAN_FILE"
cfg_opt "tickets"  "$TICKET_IDS"
cfg_opt "type"     "$FILTER_TYPE"
cfg_opt "priority" "${FILTER_PRIORITY:+<= $FILTER_PRIORITY}"
cfg_opt "owner"    "$FILTER_OWNER"
cfg_opt "tag"      "$FILTER_TAG"
cfg_opt "test"     "$TEST_CMD"
(( WATCHDOG_TIMEOUT > 0 )) && cfg_opt "watchdog" "${WATCHDOG_TIMEOUT}m" || true
[[ "$RESPECT_DEPS" == true ]] && detail "respect-deps: yes" || true
if [[ -n "$MODEL" ]]; then
  detail "model (all): $(short_model "$MODEL")"
else
  detail "models: worker=$(short_model "$WORKER_MODEL")  simplify=$(short_model "$SIMPLIFY_MODEL")  review=$(short_model "$REVIEWER_MODEL")  commit=$(short_model "$COMMIT_MODEL")"
  detail "        final=$(short_model "$FINAL_REVIEW_MODEL")  summary=$(short_model "$SUMMARY_MODEL")"
  [[ -n "$PLAN_FILE" ]] && detail "        lead=$(short_model "$LEAD_MODEL")  spec=$(short_model "$SPEC_MODEL")" || true
  [[ "$TRIAGE" == true ]] && detail "        triage=$(short_model "$TRIAGE_MODEL")" || true
fi

# Load project-specific rules once (injected into worker prompts)
project_rules=""
[[ -f "$RALPH_RULES_FILE" ]] && project_rules=$(<"$RALPH_RULES_FILE")

# Cost tracking — associative array by agent type
declare -A AGENT_COSTS
extract_cost() {
  local agent_type="$1" log_file="$2"
  local cost
  cost=$(jq -r 'select(.type == "result") | .total_cost_usd // 0' "$log_file" 2>/dev/null | tail -1)
  if [[ -n "$cost" && "$cost" != "0" && "$cost" != "null" ]]; then
    AGENT_COSTS[$agent_type]=$(echo "${AGENT_COSTS[$agent_type]:-0} + $cost" | bc 2>/dev/null || echo "${AGENT_COSTS[$agent_type]:-0}")
  fi
}

# ---------------------------------------------------------------------------
# --from-plan: decompose a plan file into tickets, then fall through to loop
# ---------------------------------------------------------------------------
if [[ -n "$PLAN_FILE" ]]; then
  # plan_title and plan_body were read before stashing (see above)

  # Derive a tag slug from the plan title for grouping
  PLAN_TAG=$(slugify "$plan_title")
  [[ -z "$PLAN_TAG" ]] && { echo "Could not generate tag from plan title: $plan_title" >&2; exit 1; }
  [[ -n "$FILTER_TAG" ]] && detail "note: --tag '$FILTER_TAG' overridden by plan tag '$PLAN_TAG'"
  FILTER_TAG="$PLAN_TAG"
  detail "tag: $PLAN_TAG"

  # --- Phase 1: Decompose epic into tasks ---
  phase_hdr "$C_BLUE" "Lead — $(short_model "$LEAD_MODEL")"
  lead_log="$LOG_DIR/lead-$(date '+%H%M%S').log"

  run_agent ralph_stream_filter "$lead_log" "$LEAD_MODEL" --output-format stream-json --verbose -p "$(
    export PLAN_TITLE="$plan_title" PLAN_BODY="$plan_body" PLAN_TAG="$PLAN_TAG"
    render_prompt "$PROMPTS_DIR/lead.md" PLAN_TITLE PLAN_BODY PLAN_TAG
  )" || true
  extract_cost "lead" "$lead_log"
  read -r dur cost <<< "$(extract_result "$lead_log")"
  out "${C_GREEN}✓${C_RESET}" "${C_DIM}$(fmt_duration "$dur") · \$$(fmt_cost "$cost")${C_RESET}"

  # --- Phase 2: Validate specs ---
  phase_hdr "$C_MAGENTA" "Spec review — $(short_model "$SPEC_MODEL")"
  spec_log="$LOG_DIR/spec-review-$(date '+%H%M%S').log"
  children_json=$(vima list --tag "$PLAN_TAG" --status open 2>/dev/null) || children_json="[]"

  run_agent ralph_stream_filter "$spec_log" "$SPEC_MODEL" --output-format stream-json --verbose -p "$(
    export CHILDREN_JSON="$children_json"
    render_prompt "$PROMPTS_DIR/spec-review.md" CHILDREN_JSON
  )" || true
  extract_cost "spec" "$spec_log"
  read -r dur cost <<< "$(extract_result "$spec_log")"
  out "${C_GREEN}✓${C_RESET}" "${C_DIM}$(fmt_duration "$dur") · \$$(fmt_cost "$cost")${C_RESET}"

  # FILTER_TAG is set — fall through into the main worker+reviewer loop
fi

# ---------------------------------------------------------------------------
# --triage: evaluate and refine tickets before the worker loop
# ---------------------------------------------------------------------------
DEFERRED_FILE="$LOG_DIR/.deferred"
: > "$DEFERRED_FILE"

if [[ "$TRIAGE" == true ]]; then
  # Gather ready tickets using the same filters the main loop would use
  triage_ready_args=()
  [[ -n "$FILTER_TAG" ]]      && triage_ready_args+=(--tag "$FILTER_TAG")
  [[ -n "$FILTER_TYPE" ]]     && triage_ready_args+=(--type "$FILTER_TYPE")
  [[ -n "$FILTER_PRIORITY" ]] && triage_ready_args+=(--priority "$FILTER_PRIORITY")
  [[ -n "$FILTER_OWNER" ]]    && triage_ready_args+=(--assignee "$FILTER_OWNER")

  triage_tickets_json=$(vima ready "${triage_ready_args[@]}" 2>/dev/null) || triage_tickets_json="[]"
  triage_count=$(echo "$triage_tickets_json" | jq 'length')

  if [[ "$triage_count" -gt 0 ]]; then
    echo ""
    phase_hdr "$C_CYAN" "Triage ($triage_count ticket(s)) — $(short_model "$TRIAGE_MODEL")"

    triage_log="$LOG_DIR/triage-$(date '+%H%M%S').log"

    run_agent ralph_stream_filter "$triage_log" "$TRIAGE_MODEL" --output-format stream-json --verbose -p "$(
      export TICKETS_JSON="$triage_tickets_json" PROJECT_RULES="$project_rules"
      render_prompt "$PROMPTS_DIR/triage.md" TICKETS_JSON PROJECT_RULES
    )" || true

    extract_cost "triage" "$triage_log"
    read -r dur cost <<< "$(extract_result "$triage_log")"
    out "${C_GREEN}✓${C_RESET}" "${C_DIM}$(fmt_duration "$dur") · \$$(fmt_cost "$cost")${C_RESET}"

    # Parse triage results from agent output
    triage_output=$(jq -r 'select(.type == "assistant") | .message.content[]? | select(.type == "text") | .text' "$triage_log" 2>/dev/null)
    triage_block=$(echo "$triage_output" | sed -n '/^TRIAGE_RESULTS$/,/^TRIAGE_RESULTS_END$/p')

    approved=0 refined=0 deferred=0
    while IFS= read -r line; do
      [[ "$line" == "TRIAGE_RESULTS" || "$line" == "TRIAGE_RESULTS_END" || -z "$line" ]] && continue
      tid=$(echo "$line" | grep -oP '^[^:]+' | tr -d ' ')
      [[ -z "$tid" ]] && continue

      if [[ "$line" == *"APPROVED"* ]]; then
        approved=$((approved + 1))
        out "${C_GREEN}✓${C_RESET}" "$tid: approved"
      elif [[ "$line" == *"REFINED"* ]]; then
        refined=$((refined + 1))
        summary=$(echo "$line" | sed 's/.*REFINED[[:space:]]*—[[:space:]]*//')
        out "${C_CYAN}✎${C_RESET}" "$tid: refined — $summary"
      elif [[ "$line" == *"DEFERRED"* ]]; then
        deferred=$((deferred + 1))
        reason=$(echo "$line" | sed 's/.*DEFERRED[[:space:]]*—[[:space:]]*//')
        out "${C_YELLOW}⏸${C_RESET}" "$tid: deferred — $reason"
        echo "$tid" >> "$DEFERRED_FILE"
      fi
    done <<< "$triage_block"

    echo ""
    detail "approved: $approved  refined: $refined  deferred: $deferred"

    # Write triage report if there are deferred tickets
    if [[ $deferred -gt 0 ]]; then
      report_file="$LOG_DIR/triage-report-$(date '+%Y%m%d-%H%M%S').md"
      report_log="$LOG_DIR/triage-report-gen.log"

      phase_hdr "$C_YELLOW" "Triage report"
      run_agent _discard "$report_log" "$SUMMARY_MODEL" -p "$(
        export TRIAGE_LOG="$triage_log" REPORT_FILE="$report_file"
        render_prompt "$PROMPTS_DIR/triage-report.md" TRIAGE_LOG REPORT_FILE
      )" || true
      extract_cost "triage-report" "$report_log"

      if [[ -f "$report_file" ]]; then
        echo ""
        cat "$report_file"
        echo ""
        out "${C_YELLOW}⚠${C_RESET}" "Deferred tickets need your attention (tagged ${C_BOLD}needs-input${C_RESET})"
        detail "report: $report_file"
      fi
    fi

    if [[ "$TRIAGE_ONLY" == true ]]; then
      section "${C_GREEN}Triage complete${C_RESET}"
      # Print cost report and exit
      if [[ "${AGENT_COSTS[@]+x}" ]]; then
        section "Cost"
        total=0
        for agent_type in "${!AGENT_COSTS[@]}"; do
          cost="${AGENT_COSTS[$agent_type]}"
          printf "    %-20s \$%s\n" "$agent_type" "$(fmt_cost "$cost")"
          total=$(echo "$total + $cost" | bc 2>/dev/null || echo "$total")
        done
        printf "    ${C_BOLD}%-20s \$%s${C_RESET}\n" "total" "$(fmt_cost "$total")"
      fi
      # Restore shelved untracked files
      if [[ -n "$STASH_DIR" && -d "$STASH_DIR" ]]; then
        cp -a "$STASH_DIR"/. . 2>/dev/null || true
        rm -rf "$STASH_DIR"
      fi
      exit 0
    fi
  else
    detail "no ready tickets to triage"
    if [[ "$TRIAGE_ONLY" == true ]]; then
      # Restore shelved untracked files
      if [[ -n "$STASH_DIR" && -d "$STASH_DIR" ]]; then
        cp -a "$STASH_DIR"/. . 2>/dev/null || true
        rm -rf "$STASH_DIR"
      fi
      exit 0
    fi
  fi
fi

PRE_LOOP_HEAD=$(git rev-parse --verify HEAD 2>/dev/null || git hash-object -t tree /dev/null)

# ---------------------------------------------------------------------------
# --review-only: skip worker loop, jump to final review
# ---------------------------------------------------------------------------
if [[ "$REVIEW_ONLY" == true ]]; then
  if [[ -n "$REVIEW_ONLY_REF" ]]; then
    PRE_LOOP_HEAD=$(git rev-parse --verify "$REVIEW_ONLY_REF" 2>/dev/null) \
      || { echo "Cannot resolve ref: $REVIEW_ONLY_REF" >&2; exit 1; }
  fi
  iteration=1  # satisfy the iteration-gt-0 guards
  section "Review-only mode — diffing from ${PRE_LOOP_HEAD:0:7}..HEAD"
  git diff --stat "$PRE_LOOP_HEAD"..HEAD | while IFS= read -r line; do detail "  $line"; done
fi

# ---------------------------------------------------------------------------
# Main loop — runs as long as there are unblocked tickets
# ---------------------------------------------------------------------------
while [[ "$REVIEW_ONLY" != true ]]; do
  # -----------------------------------------------------------------------
  # Pick next ticket — explicit list, filtered ready, or default ready
  # -----------------------------------------------------------------------
  ticket_id=""
  ticket_title=""
  ticket_type=""

  if [[ "$EXPLICIT_MODE" == true ]]; then
    # Explicit ticket list — stop when exhausted
    if [[ -z "$TICKET_IDS" ]]; then
      break
    fi

    if [[ "$RESPECT_DEPS" == true ]]; then
      # Scan the list for the first ticket whose dependencies are all closed.
      # Tickets that are still blocked get re-queued at the end.
      remaining=""
      found=false

      IFS=',' read -ra candidates <<< "$TICKET_IDS"
      for candidate in "${candidates[@]}"; do
        if [[ "$found" == true ]]; then
          # Already picked one — keep the rest as-is
          remaining="${remaining:+$remaining,}$candidate"
          continue
        fi

        if grep -qxF "$candidate" "$SKIP_FILE" 2>/dev/null; then
          continue   # failed earlier — drop from list
        fi
        if grep -qxF "$candidate" "$DEFERRED_FILE" 2>/dev/null; then
          continue   # deferred by triage — needs human input
        fi

        # Check if all dependencies are closed
        ready_check=$(vima is-ready "$candidate" 2>/dev/null) || ready_check='{"ready":false}'
        is_candidate_ready=$(echo "$ready_check" | jq -r '.ready')

        if [[ "$is_candidate_ready" != "true" ]]; then
          # Still blocked — re-queue at the end
          remaining="${remaining:+$remaining,}$candidate"
        else
          # Ready to go
          ticket_id="$candidate"
          ticket_json=$(vima show "$candidate" 2>/dev/null) || ticket_json="{}"
          ticket_title=$(ticket_field "$ticket_json" title unknown)
          ticket_type=$(ticket_field "$ticket_json" type task)
          found=true
        fi
      done

      TICKET_IDS="$remaining"

      if [[ "$found" == false ]]; then
        if [[ -n "$remaining" ]]; then
          section "${C_YELLOW}All remaining tickets are blocked${C_RESET}"
          detail "${remaining//,/, }"
        fi
        break
      fi
    else
      # No dep checking — pop first ID from the comma-separated list
      ticket_id="${TICKET_IDS%%,*}"
      rest="${TICKET_IDS#*,}"
      [[ "$rest" == "$ticket_id" ]] && rest=""   # was the last item
      TICKET_IDS="$rest"

      if grep -qxF "$ticket_id" "$SKIP_FILE" 2>/dev/null; then
        continue   # already failed — skip silently
      fi
      if grep -qxF "$ticket_id" "$DEFERRED_FILE" 2>/dev/null; then
        continue   # deferred by triage — needs human input
      fi

      # Resolve title/type from vima show
      ticket_json=$(vima show "$ticket_id" 2>/dev/null) || ticket_json="{}"
      ticket_title=$(ticket_field "$ticket_json" title unknown)
      ticket_type=$(ticket_field "$ticket_json" type task)
    fi
  else
    # Default mode — ask vima ready with passthrough filters
    ready_args=()
    [[ -n "$FILTER_TAG" ]]      && ready_args+=(--tag "$FILTER_TAG")
    [[ -n "$FILTER_TYPE" ]]     && ready_args+=(--type "$FILTER_TYPE")
    [[ -n "$FILTER_PRIORITY" ]] && ready_args+=(--priority "$FILTER_PRIORITY")
    [[ -n "$FILTER_OWNER" ]]    && ready_args+=(--assignee "$FILTER_OWNER")

    ready_json=$(vima ready "${ready_args[@]}" 2>/dev/null) || ready_json="[]"

    # Pick first not already skipped
    count=$(echo "$ready_json" | jq 'length')
    for i in $(seq 0 $((count - 1))); do
      candidate=$(echo "$ready_json" | jq -r ".[$i].id")
      if ! grep -qxF "$candidate" "$SKIP_FILE" 2>/dev/null \
         && ! grep -qxF "$candidate" "$DEFERRED_FILE" 2>/dev/null; then
        ticket_id="$candidate"
        ticket_title=$(echo "$ready_json" | jq -r ".[$i].title")
        ticket_type=$(echo "$ready_json" | jq -r ".[$i].type")
        break
      fi
    done
  fi

  if [[ -z "$ticket_id" ]]; then
    section "${C_GREEN}No more ready tickets — done${C_RESET}"
    break
  fi

  iteration=$((iteration + 1))
  if [[ $iteration -gt $MAX_ITERATIONS ]]; then
    section "${C_YELLOW}Reached max iterations ($MAX_ITERATIONS)${C_RESET}"
    exit 1
  fi

  section "Iteration $iteration — $ticket_id"
  detail "$ticket_title"

  # Claim the ticket
  vima start "$ticket_id" > /dev/null 2>&1 || true

  # -----------------------------------------------------------------------
  # Build the prompt — fresh context each time (core Ralph insight)
  # -----------------------------------------------------------------------
  ticket_details=$(vima show "$ticket_id" --pretty 2>/dev/null)
  ticket_show_json=$(vima show "$ticket_id" 2>/dev/null) || ticket_show_json="{}"
  acceptance=$(echo "$ticket_show_json" | jq -r '.acceptance // empty')
  ticket_tags=$(echo "$ticket_show_json" | jq -r '.tags // [] | map("--tags " + .) | join(" ")') || ticket_tags=""
  prompt_file=$(mktemp /tmp/ralph-prompt.XXXXXX)

  (
    export TICKET_TAGS="$ticket_tags" TICKET_ID="$ticket_id"
    export PROJECT_RULES="$project_rules" TICKET_DETAILS="$ticket_details"
    export ACCEPTANCE="$acceptance"
    render_prompt "$PROMPTS_DIR/worker.md" TICKET_TAGS TICKET_ID PROJECT_RULES TICKET_DETAILS ACCEPTANCE
  ) > "$prompt_file"

  # -----------------------------------------------------------------------
  # Run Claude — retry on failure
  # -----------------------------------------------------------------------
  pre_worker_head=$(git rev-parse HEAD 2>/dev/null || git hash-object -t tree /dev/null)
  log_file="$LOG_DIR/iter-${iteration}-${ticket_id}.log"
  retries=0
  success=false

  while [[ $retries -lt $MAX_RETRIES ]]; do
    echo ""
    if [[ $MAX_RETRIES -gt 1 ]]; then
      phase_hdr "$C_BLUE" "Worker (attempt $((retries + 1))/$MAX_RETRIES) — $(short_model "$WORKER_MODEL")"
    else
      phase_hdr "$C_BLUE" "Worker — $(short_model "$WORKER_MODEL")"
    fi
    run_agent ralph_stream_filter "$log_file" "$WORKER_MODEL" --output-format stream-json --verbose \
      < "$prompt_file" || true

    # Check success from the stream-json result event (not pipeline exit code)
    extract_cost "worker" "$log_file"
    if jq -e 'select(.type == "result" and .subtype == "success")' "$log_file" > /dev/null 2>&1; then
      read -r dur cost <<< "$(extract_result "$log_file")"
      out "${C_GREEN}✓${C_RESET}" "${C_DIM}$(fmt_duration "$dur") · \$$(fmt_cost "$cost")${C_RESET}"
      # --- Pre-commit test gate ---
      if [[ -n "$TEST_CMD" ]]; then
        echo ""
        phase_hdr "$C_CYAN" "Test gate"
        test_gate_log="$LOG_DIR/iter-${iteration}-${ticket_id}-test-${retries}.log"
        if eval "$TEST_CMD" > "$test_gate_log" 2>&1; then
          out "${C_GREEN}✓${C_RESET}" "passed"
        else
          out "${C_RED}✗${C_RESET}" "failed"
          retries=$((retries + 1))
          if [[ $retries -lt $MAX_RETRIES ]]; then
            # Augment prompt with test failure output for next worker attempt
            test_snippet=$(tail -80 "$test_gate_log")
            cat >> "$prompt_file" <<TESTFAIL

## Test Failures (attempt $retries)

Your previous changes cause test/typecheck failures. You MUST fix these.

Command: $TEST_CMD
Output (last 80 lines):
\`\`\`
$test_snippet
\`\`\`
TESTFAIL
            out "${C_YELLOW}↻${C_RESET}" "retrying worker with test output..."
            sleep 2
            continue
          fi
          # Exhausted retries on test failure
          break
        fi
      fi
      success=true
      break
    fi

    retries=$((retries + 1))
    if [[ $retries -lt $MAX_RETRIES ]]; then
      out "${C_YELLOW}✗${C_RESET}" "failed, retrying in 5s..."
      sleep 5
    fi
  done

  rm -f "$prompt_file"

  if [[ "$success" == false ]]; then
    out "${C_RED}✗${C_RESET}" "failed after $MAX_RETRIES attempts — skipping $ticket_id"
    echo "$ticket_id" >> "$SKIP_FILE"
    vima update "$ticket_id" --status open > /dev/null 2>&1 || true   # release claim
    continue
  fi

  # -----------------------------------------------------------------------
  # Skip commit & review if worker made no code changes
  # -----------------------------------------------------------------------
  if ! has_code_changes; then
    detail "no code changes — skipping commit & review"
    vima close "$ticket_id" --reason "No changes needed (iteration $iteration)" > /dev/null 2>&1 || true
    out "${C_GREEN}✓${C_RESET}" "Closed $ticket_id"
    sleep 2
    continue
  fi

  # -----------------------------------------------------------------------
  # Commit code changes.
  # .ralph-logs/ and .vima/ are script-internal and excluded.
  # Exclude pathspecs (:!) don't play well with git add, so we use
  # add-then-reset instead.
  # -----------------------------------------------------------------------
  echo ""
  commit_log="$LOG_DIR/iter-${iteration}-${ticket_id}-commit.log"
  run_agent _discard "$commit_log" "$COMMIT_MODEL" -p "$(
    export TICKET_ID="$ticket_id"
    render_prompt "$PROMPTS_DIR/commit.md" TICKET_ID
  )" \
    && phase_hdr "$C_YELLOW" "Commit ${C_GREEN}✓${C_RESET}" \
    || phase_hdr "$C_YELLOW" "Commit ${C_RED}✗${C_RESET}"

  # -----------------------------------------------------------------------
  # Simplify — fix reuse, quality, and efficiency issues before review
  # Skipped when the worker diff is smaller than SIMPLIFY_THRESHOLD lines.
  # -----------------------------------------------------------------------
  changed_lines=$(git diff --stat "$pre_worker_head"..HEAD -- ':!.ralph-logs' ':!.vima' 2>/dev/null | tail -1 | grep -oP '\d+(?= (insertion|file))' | head -1 || true)
  del_lines=$(git diff --stat "$pre_worker_head"..HEAD -- ':!.ralph-logs' ':!.vima' 2>/dev/null | tail -1 | grep -oP '\d+(?= deletion)' || true)
  changed_lines=$(( ${changed_lines:-0} + ${del_lines:-0} ))

  if (( changed_lines >= SIMPLIFY_THRESHOLD )); then
    echo ""
    phase_hdr "$C_CYAN" "Simplify — $(short_model "$SIMPLIFY_MODEL")"
    simplify_log="$LOG_DIR/iter-${iteration}-${ticket_id}-simplify.log"

    run_agent ralph_stream_filter "$simplify_log" "$SIMPLIFY_MODEL" --output-format stream-json --verbose -p "$(
      export PRE_WORKER_HEAD="$pre_worker_head"
      render_prompt "$PROMPTS_DIR/simplify.md" PRE_WORKER_HEAD
    )" || true

    extract_cost "simplify" "$simplify_log"
    if jq -e 'select(.type == "result" and .subtype == "success")' "$simplify_log" > /dev/null 2>&1; then
      read -r dur cost <<< "$(extract_result "$simplify_log")"
      out "${C_GREEN}✓${C_RESET}" "${C_DIM}$(fmt_duration "$dur") · \$$(fmt_cost "$cost")${C_RESET}"
      # Commit any simplify changes
      if ! git diff --quiet HEAD -- ':!.ralph-logs' ':!.vima' 2>/dev/null || \
         git ls-files --others --exclude-standard -- ':!.ralph-logs' ':!.vima' 2>/dev/null | grep -q .; then
        simplify_commit_log="$LOG_DIR/iter-${iteration}-${ticket_id}-simplify-commit.log"
        run_agent _discard "$simplify_commit_log" "$COMMIT_MODEL" -p "$(
          export TICKET_ID="$ticket_id"
          render_prompt "$PROMPTS_DIR/commit.md" TICKET_ID
        )" || true
      fi
    else
      out "${C_YELLOW}✗${C_RESET}" "simplify failed — continuing"
    fi
  else
    detail "skipping simplify — only $changed_lines lines changed (threshold: $SIMPLIFY_THRESHOLD)"
  fi

  # -----------------------------------------------------------------------
  # Review the work — fresh Claude instance, read-only
  # -----------------------------------------------------------------------
  echo ""
  phase_hdr "$C_MAGENTA" "Review — $(short_model "$REVIEWER_MODEL")"
  review_log="$LOG_DIR/iter-${iteration}-${ticket_id}-review.log"

  run_agent _discard "$review_log" "$REVIEWER_MODEL" --output-format stream-json --verbose -p "$(
    export TICKET_DETAILS="$ticket_details" TICKET_ID="$ticket_id"
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS="$ticket_tags"
    render_prompt "$PROMPTS_DIR/review.md" TICKET_DETAILS TICKET_ID PRE_LOOP_HEAD TICKET_TAGS
  )" || true

  extract_cost "reviewer" "$review_log"
  review_result=$(jq -r 'select(.type == "assistant") | .message.content[]? | select(.type == "text") | .text' "$review_log" 2>/dev/null | tail -1)
  if [[ "$review_result" == *"REVIEW_PASS"* ]]; then
    out "${C_GREEN}✓${C_RESET}" "pass"
  elif [[ "$review_result" == *"REVIEW_ISSUES_FILED"* ]]; then
    extract_filed_tickets "$review_log"
    out "${C_MAGENTA}●${C_RESET}" "issues filed"
  else
    out "${C_DIM}?${C_RESET}" "${review_result:-(no verdict)}"
  fi

  # -----------------------------------------------------------------------
  # Close the ticket (or release if blocked)
  # -----------------------------------------------------------------------
  ready_check=$(vima is-ready "$ticket_id" 2>/dev/null) || ready_check='{"ready":true}'
  is_ticket_ready=$(echo "$ready_check" | jq -r '.ready')

  if [[ "$is_ticket_ready" != "true" ]]; then
    open_blockers=$(echo "$ready_check" | jq '.open_deps | length')
    out "${C_YELLOW}●${C_RESET}" "$ticket_id has $open_blockers open blocker(s) — released"
    vima update "$ticket_id" --status open > /dev/null 2>&1 || true
  else
    vima close "$ticket_id" --reason "Completed by ralph (iteration $iteration)" > /dev/null 2>&1 || true
    echo ""
    out "${C_GREEN}✓${C_RESET}" "Closed $ticket_id"
  fi
  sleep 2
done

# ---------------------------------------------------------------------------
# Wrap up
# ---------------------------------------------------------------------------
# Restore shelved untracked files
if [[ -n "$STASH_DIR" && -d "$STASH_DIR" ]]; then
  cp -a "$STASH_DIR"/. . 2>/dev/null || true
  rm -rf "$STASH_DIR"
  detail "restored shelved untracked files"
fi

if [[ "$REVIEW_ONLY" != true ]]; then
  section "Completed — $iteration iteration(s)"
  if [[ -s "$SKIP_FILE" ]]; then
    detail "skipped (failed after retries):"
    while IFS= read -r id; do detail "  - $id"; done < "$SKIP_FILE"
  fi
fi

# ---------------------------------------------------------------------------
# Diff stats + final review personas
# ---------------------------------------------------------------------------
final_review_failed=false

if [[ $iteration -gt 0 ]]; then
  if [[ "$REVIEW_ONLY" != true ]]; then
    echo ""
    detail "diff stats:"
    git diff --stat "$PRE_LOOP_HEAD"..HEAD | while IFS= read -r line; do detail "  $line"; done
  fi

  # Build plan context — from --from-plan flag or PLAN.md in repo
  plan_context=""
  if [[ -n "${plan_body:-}" ]]; then
    plan_context="## Original Plan
# ${plan_title}
${plan_body}"
  elif [[ -f "PLAN.md" ]]; then
    plan_context="## Original Plan (from PLAN.md)
$(cat PLAN.md)"
  fi

  # Count active personas
  persona_count=3
  [[ -n "$plan_context" ]] && persona_count=4

  echo ""
  phase_hdr "$C_MAGENTA" "Final review ($persona_count personas) — $(short_model "$FINAL_REVIEW_MODEL")"

  closed_tickets=""
  if [[ -n "${FILTER_TAG:-}" ]]; then
    closed_tickets=$(vima list --tag "$FILTER_TAG" --status closed 2>/dev/null) || closed_tickets="[]"
  fi
  skipped=""; [[ -s "$SKIP_FILE" ]] && skipped=$(cat "$SKIP_FILE")

  ticket_tags_flag="${FILTER_TAG:+--tags $FILTER_TAG}"

  # --- Persona A: Security Reviewer ---
  sec_log="$LOG_DIR/final-review-security-$(date '+%H%M%S').log"
  run_agent _discard "$sec_log" "$FINAL_REVIEW_MODEL" --output-format stream-json --verbose -p "$(
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
    render_prompt "$PROMPTS_DIR/final-review-security.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG
  )" &
  sec_pid=$!

  # --- Persona B: Integration Reviewer ---
  int_log="$LOG_DIR/final-review-integration-$(date '+%H%M%S').log"
  run_agent _discard "$int_log" "$FINAL_REVIEW_MODEL" --output-format stream-json --verbose -p "$(
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
    render_prompt "$PROMPTS_DIR/final-review-integration.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG
  )" &
  int_pid=$!

  # --- Persona C: Codebase Patterns Reviewer ---
  pat_log="$LOG_DIR/final-review-patterns-$(date '+%H%M%S').log"
  run_agent _discard "$pat_log" "$FINAL_REVIEW_MODEL" --output-format stream-json --verbose -p "$(
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
    render_prompt "$PROMPTS_DIR/final-review-patterns.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG
  )" &
  pat_pid=$!

  # --- Persona D: Plan Adherence Reviewer (conditional) ---
  plan_pid=""
  plan_log=""
  if [[ -n "$plan_context" ]]; then
    plan_log="$LOG_DIR/final-review-plan-$(date '+%H%M%S').log"
    run_agent _discard "$plan_log" "$FINAL_REVIEW_MODEL" --output-format stream-json --verbose -p "$(
      export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
      export PLAN_CONTEXT="$plan_context"
      render_prompt "$PROMPTS_DIR/final-review-plan.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG PLAN_CONTEXT
    )" &
    plan_pid=$!
  fi

  # Wait for all final reviewers
  wait "$sec_pid" "$int_pid" "$pat_pid" ${plan_pid:+"$plan_pid"} 2>/dev/null || true

  # Collect results
  for logvar in sec_log int_log pat_log ${plan_context:+plan_log}; do
    logfile="${!logvar}"
    [[ -z "$logfile" || ! -f "$logfile" ]] && continue
    label=$(basename "$logfile" .log | sed 's/final-review-//' | sed 's/-[0-9]*//')
    extract_cost "final-$label" "$logfile"
    result=$(jq -r 'select(.type == "assistant") | .message.content[]? | select(.type == "text") | .text' "$logfile" 2>/dev/null | tail -1)
    if [[ "$result" == *"_PASS"* ]]; then
      out "${C_GREEN}✓${C_RESET}" "${label}: pass"
    elif [[ "$result" == *"_ISSUES"* ]]; then
      out "${C_MAGENTA}●${C_RESET}" "${label}: issues filed"
      extract_filed_tickets "$logfile"
      final_review_failed=true
    else
      out "${C_DIM}?${C_RESET}" "${label}: ${result:-(no verdict)}"
    fi
  done
fi

# ---------------------------------------------------------------------------
# Post-run summary — read all work logs and extract learnings
# ---------------------------------------------------------------------------
if [[ $iteration -gt 0 ]]; then
  echo ""
  detail "generating summary..."
  summary_file="$LOG_DIR/summary-$(date '+%Y%m%d-%H%M%S').md"

  # Collect work logs (skip commit logs)
  log_list=""
  for f in "$LOG_DIR"/iter-*; do
    [[ "$f" == *-commit.log ]] && continue
    [[ -f "$f" ]] && log_list="$log_list $f"
  done

  if [[ -n "$log_list" ]]; then
    run_agent _discard "$summary_file" "$SUMMARY_MODEL" -p "$(
      export LOG_LIST="$log_list" SKIP_FILE="$SKIP_FILE"
      export GENERATED_TS="$(date '+%Y-%m-%d %H:%M:%S')"
      render_prompt "$PROMPTS_DIR/summary.md" LOG_LIST SKIP_FILE GENERATED_TS
    )"

    echo ""
    cat "$summary_file"
  fi
fi

# ---------------------------------------------------------------------------
# Cost report
# ---------------------------------------------------------------------------
if [[ "${AGENT_COSTS[@]+x}" ]]; then
  section "Cost"
  total=0
  for agent_type in "${!AGENT_COSTS[@]}"; do
    cost="${AGENT_COSTS[$agent_type]}"
    printf "    %-20s \$%s\n" "$agent_type" "$(fmt_cost "$cost")"
    total=$(echo "$total + $cost" | bc 2>/dev/null || echo "$total")
  done
  printf "    ${C_BOLD}%-20s \$%s${C_RESET}\n" "total" "$(fmt_cost "$total")"
fi

# ---------------------------------------------------------------------------
# Exit code — non-zero if final review found issues
# ---------------------------------------------------------------------------
if [[ "${final_review_failed:-false}" == true ]]; then
  exit 1
fi
