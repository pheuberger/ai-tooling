#!/usr/bin/env bash
# ralph-review — Standalone final review of branch changes vs a base branch
#
# Spawns parallel Claude personas that review `git diff <base>..HEAD` and
# file vima tickets for issues found.
#
# Two modes:
#   --full   (default) 5 personas: security, integration, patterns,
#            maintainability, performance, plus plan-adherence if PLAN.md exists
#   --light  2 personas: pragmatic-security + integration-light. No kaizen.
#
# Usage: ./ralph-review [options]
#   --full              Full deep review (default)
#   --light             Light pragmatic review
#   --base REF          Base ref to diff against — branch name or commit hash
#                       (default: main). Branches use merge-base with HEAD;
#                       commit hashes/tags are used directly as the base.
#   --tag TAG           Tag added to filed tickets
#   --model MODEL       Override review model
#   --log-dir DIR       Log directory (default: .ralph-logs/review)
#   --plan FILE         Plan file for plan-adherence persona (default: PLAN.md)
#   --no-plan           Skip plan-adherence persona even if PLAN.md exists
#   -h, --help          Show usage
#
# Configuration:
#   .ralphrc            Sourced from project root before CLI args are parsed.
#                       Set FINAL_REVIEW_MODEL to change default model.
#
# Requires: claude (Claude Code CLI), vima, jq, git, envsubst

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROMPTS_DIR="${PROMPTS_DIR:-$SCRIPT_DIR/prompts}"

# ---------------------------------------------------------------------------
# Colors + helpers (mirrors ralph)
# ---------------------------------------------------------------------------
C_RESET='\033[0m'
C_BOLD='\033[1m'
C_DIM='\033[2m'
C_CYAN='\033[36m'
C_GREEN='\033[32m'
C_YELLOW='\033[33m'
C_MAGENTA='\033[35m'
C_RED='\033[31m'

ts()         { printf '%s' "$(date '+%Y-%m-%d %H:%M:%S')"; }
log_ts()     { echo -e "${C_DIM}[$(ts)]${C_RESET} $*"; }
out()        { echo -e "  $1 $2"; }
detail()     { echo -e "    ${C_DIM}$1${C_RESET}"; }
section()    { echo -e "\n${C_BOLD}$1${C_RESET}"; }
phase_hdr()  { echo -e "  ${1}●${C_RESET} ${C_BOLD}${2}${C_RESET}"; }
short_model() { echo "$1" | sed 's/^claude-//; s/-[0-9].*//'; }

# render_prompt <template_file> [VAR1 VAR2 ...]
render_prompt() {
  local template="$1"; shift
  [[ -f "$template" ]] || { echo "Missing prompt template: $template" >&2; return 1; }

  local content
  content=$(<"$template")

  while [[ "$content" =~ \{\{#IF\ ([A-Z_]+)\}\} ]]; do
    local var_name="${BASH_REMATCH[1]}"
    local var_val="${!var_name:-}"
    if [[ -n "$var_val" ]]; then
      content=$(echo "$content" | sed "/{{#IF ${var_name}}}/d; /{{\/IF ${var_name}}}/d")
    else
      content=$(echo "$content" | sed "/{{#IF ${var_name}}}/,/{{\/IF ${var_name}}}/d")
    fi
  done

  local varlist=""
  for v in "$@"; do varlist="$varlist \${$v}"; done

  echo "$content" | envsubst "$varlist"
}

# Stream filter — readable progress from stream-json
ralph_stream_filter() {
  jq --unbuffered -r '
    if .type == "assistant" then
      [.message.content[]? |
        if .type == "tool_use" then
          (.input // {}) as $in |
          (.name as $n |
            if   $n == "Bash"   then $in.command // ""
            elif $n == "Edit"   then $in.file_path // ""
            elif $n == "Read"   then $in.file_path // ""
            elif $n == "Write"  then $in.file_path // ""
            elif $n == "Grep"   then ($in.pattern // "") + " " + ($in.path // "")
            elif $n == "Glob"   then $in.pattern // ""
            else "" end
          ) as $detail |
          "    \u001b[36m>>> " + .name + "\u001b[2m " + ($detail | .[0:120]) + "\u001b[0m"
        else empty end
      ] | join("\n") | select(length > 0)
    else empty end
  ' 2>/dev/null
}

# Parse vima create commands + resulting IDs from a review log.
# Emits tab-delimited records: kind\tpriority\tid\ttitle
# kind = "fix" or "kaizen" (derived from title prefix)
parse_filed_tickets() {
  local log="$1"
  jq -rs --compact-output '
    . as $all |
    [$all[] | select(.type == "assistant") | .message.content[]? |
      select(.type == "tool_use" and .name == "Bash") |
      select(.input.command | test("vima create"))] as $cmds |
    [$all[] | select(.type == "user") | .message.content[]? |
      select(.type == "tool_result")] as $results |
    $cmds[] |
    . as $c |
    ($results | map(select(.tool_use_id == $c.id)) | .[0]) as $r |
    {
      command: $c.input.command,
      output: ($r // {} | .content | if type == "string" then . elif type == "array" then (.[0].text // "") else "" end)
    }
  ' "$log" 2>/dev/null | while IFS= read -r json; do
    [[ -z "$json" ]] && continue
    cmd=$(printf '%s' "$json" | jq -r '.command // ""')
    output=$(printf '%s' "$json" | jq -r '.output // ""' | tr -d '[:space:]')
    title=$(printf '%s' "$cmd" | grep -oP 'vima create "\K[^"]+' | head -1)
    [[ -z "$title" ]] && continue
    prio=$(printf '%s' "$cmd" | grep -oP -- '--priority \K[0-9]+' | head -1)
    if [[ "$output" =~ ^[a-z0-9-]+$ ]]; then
      id="$output"
    else
      id=$(printf '%s' "$output" | grep -oP '"id"\s*:\s*"\K[^"]+' | head -1)
      [[ -z "$id" ]] && id=$(printf '%s' "$output" | grep -oP '\b[a-z]{2,}-[a-z0-9]{3,}\b' | head -1)
    fi
    if [[ "$title" == Kaizen:* ]]; then
      kind="kaizen"
    else
      kind="fix"
    fi
    printf '%s\t%s\t%s\t%s\n' "$kind" "${prio:-?}" "${id:-?}" "$title"
  done
}

# Run claude with model
claude_as() {
  local model="$1"; shift
  CI=true setsid -w claude --print --dangerously-skip-permissions --model "$model" "$@"
}

# Sink — discards console output (quiet agents)
_discard() { cat > /dev/null; }

# Stream filter with persona label prefixed on each line
labeled_stream() {
  local label="$1"
  ralph_stream_filter | sed -u "s/^/    \x1b[35m[${label}]\x1b[0m/"
}

# run_agent <label> <log_file> <model> [claude args...]
run_agent() {
  local label="$1" log_file="$2" model="$3"; shift 3
  claude_as "$model" "$@" 2>&1 | tee "$log_file" | labeled_stream "$label"
}

# ---------------------------------------------------------------------------
# Defaults + config
# ---------------------------------------------------------------------------
MODE="full"
BASE_REF_INPUT="main"
FILTER_TAG=""
REVIEW_MODEL=""
LOG_DIR=".ralph-logs/review"
PLAN_FILE_ARG=""
NO_PLAN=false

# Source per-project config (CLI flags override)
if [[ -f ".ralphrc" ]]; then
  # shellcheck source=/dev/null
  source ".ralphrc"
fi

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case $1 in
    --full)     MODE="full"; shift ;;
    --light)    MODE="light"; shift ;;
    --base)     BASE_REF_INPUT="$2"; shift 2 ;;
    --tag)      FILTER_TAG="$2"; shift 2 ;;
    --model)    REVIEW_MODEL="$2"; shift 2 ;;
    --log-dir)  LOG_DIR="$2"; shift 2 ;;
    --plan)     PLAN_FILE_ARG="$2"; shift 2 ;;
    --no-plan)  NO_PLAN=true; shift ;;
    -h|--help)  sed -n '/^# Usage/,/^$/p' "$0" | sed 's/^# \?//'; exit 0 ;;
    *)          echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

REVIEW_MODEL="${REVIEW_MODEL:-${FINAL_REVIEW_MODEL:-claude-opus-4-6}}"

# ---------------------------------------------------------------------------
# Preflight
# ---------------------------------------------------------------------------
for cmd in claude vima jq git envsubst; do
  command -v "$cmd" >/dev/null 2>&1 || { echo "Required: $cmd" >&2; exit 1; }
done

# Resolve base ref. Branches use merge-base with HEAD; commits/tags used directly.
if ! git rev-parse --verify "${BASE_REF_INPUT}^{commit}" >/dev/null 2>&1; then
  echo "Base ref not found: $BASE_REF_INPUT" >&2
  exit 1
fi

if git show-ref --verify --quiet "refs/heads/$BASE_REF_INPUT" \
   || git show-ref --verify --quiet "refs/remotes/$BASE_REF_INPUT"; then
  BASE_KIND="branch"
  BASE_REF=$(git merge-base HEAD "$BASE_REF_INPUT" 2>/dev/null) \
    || { echo "Could not find merge-base between HEAD and $BASE_REF_INPUT" >&2; exit 1; }
else
  BASE_KIND="commit"
  BASE_REF=$(git rev-parse --verify "${BASE_REF_INPUT}^{commit}")
fi

# Verify there is something to review
if [[ -z "$(git diff --name-only "$BASE_REF"..HEAD)" ]]; then
  section "${C_YELLOW}No changes between $BASE_REF_INPUT and HEAD — nothing to review${C_RESET}"
  exit 0
fi

mkdir -p "$LOG_DIR"

# Resolve plan file (full mode only)
plan_context=""
plan_file=""
if [[ "$MODE" == "full" && "$NO_PLAN" != true ]]; then
  if [[ -n "$PLAN_FILE_ARG" ]]; then
    [[ -f "$PLAN_FILE_ARG" ]] || { echo "Plan file not found: $PLAN_FILE_ARG" >&2; exit 1; }
    plan_file="$PLAN_FILE_ARG"
  elif [[ -f "PLAN.md" ]]; then
    plan_file="PLAN.md"
  fi
  if [[ -n "$plan_file" ]]; then
    plan_context="## Original Plan (from ${plan_file})
$(<"$plan_file")"
  fi
fi

# ---------------------------------------------------------------------------
# Startup banner
# ---------------------------------------------------------------------------
section "Ralph Review"
detail "mode: $MODE"
detail "base: $BASE_REF_INPUT ($BASE_KIND, ${BASE_REF:0:7})"
detail "      $(git log -1 --format='%h %s' "$BASE_REF")"
detail "diff: $(git diff --shortstat "$BASE_REF"..HEAD | sed 's/^ *//')"
detail "model: $(short_model "$REVIEW_MODEL")"
[[ -n "$FILTER_TAG" ]] && detail "tag: $FILTER_TAG"
[[ -n "$plan_file" ]] && detail "plan: $plan_file"

PRE_LOOP_HEAD="$BASE_REF"
ticket_tags_flag="${FILTER_TAG:+--tags $FILTER_TAG}"

# ---------------------------------------------------------------------------
# Run personas in parallel
# ---------------------------------------------------------------------------
echo ""
if [[ "$MODE" == "light" ]]; then
  phase_hdr "$C_MAGENTA" "Light review (2 personas) — $(short_model "$REVIEW_MODEL")"

  sec_log="$LOG_DIR/pragmatic-security-$(date '+%H%M%S').log"
  run_agent "pragmatic-security" "$sec_log" "$REVIEW_MODEL" --output-format stream-json --verbose -p "$(
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
    render_prompt "$PROMPTS_DIR/final-review-pragmatic-security.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG
  )" &
  sec_pid=$!

  int_log="$LOG_DIR/integration-light-$(date '+%H%M%S').log"
  run_agent "integration-light" "$int_log" "$REVIEW_MODEL" --output-format stream-json --verbose -p "$(
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
    render_prompt "$PROMPTS_DIR/final-review-integration-light.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG
  )" &
  int_pid=$!

  wait "$sec_pid" "$int_pid" 2>/dev/null || true

  log_files=("$sec_log" "$int_log")
else
  persona_count=5
  [[ -n "$plan_context" ]] && persona_count=6
  phase_hdr "$C_MAGENTA" "Full review ($persona_count personas) — $(short_model "$REVIEW_MODEL")"

  sec_log="$LOG_DIR/security-$(date '+%H%M%S').log"
  run_agent "security" "$sec_log" "$REVIEW_MODEL" --output-format stream-json --verbose -p "$(
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
    render_prompt "$PROMPTS_DIR/final-review-security.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG
  )" &
  sec_pid=$!

  int_log="$LOG_DIR/integration-$(date '+%H%M%S').log"
  run_agent "integration" "$int_log" "$REVIEW_MODEL" --output-format stream-json --verbose -p "$(
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
    render_prompt "$PROMPTS_DIR/final-review-integration.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG
  )" &
  int_pid=$!

  pat_log="$LOG_DIR/patterns-$(date '+%H%M%S').log"
  run_agent "patterns" "$pat_log" "$REVIEW_MODEL" --output-format stream-json --verbose -p "$(
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
    render_prompt "$PROMPTS_DIR/final-review-patterns.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG
  )" &
  pat_pid=$!

  mnt_log="$LOG_DIR/maintainability-$(date '+%H%M%S').log"
  run_agent "maintainability" "$mnt_log" "$REVIEW_MODEL" --output-format stream-json --verbose -p "$(
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
    render_prompt "$PROMPTS_DIR/final-review-maintainability.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG
  )" &
  mnt_pid=$!

  perf_log="$LOG_DIR/performance-$(date '+%H%M%S').log"
  run_agent "performance" "$perf_log" "$REVIEW_MODEL" --output-format stream-json --verbose -p "$(
    export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
    render_prompt "$PROMPTS_DIR/final-review-performance.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG
  )" &
  perf_pid=$!

  plan_pid=""
  plan_log=""
  if [[ -n "$plan_context" ]]; then
    plan_log="$LOG_DIR/plan-$(date '+%H%M%S').log"
    run_agent "plan" "$plan_log" "$REVIEW_MODEL" --output-format stream-json --verbose -p "$(
      export PRE_LOOP_HEAD="$PRE_LOOP_HEAD" TICKET_TAGS_FLAG="$ticket_tags_flag"
      export PLAN_CONTEXT="$plan_context"
      render_prompt "$PROMPTS_DIR/final-review-plan.md" PRE_LOOP_HEAD TICKET_TAGS_FLAG PLAN_CONTEXT
    )" &
    plan_pid=$!
  fi

  wait "$sec_pid" "$int_pid" "$pat_pid" "$mnt_pid" "$perf_pid" ${plan_pid:+"$plan_pid"} 2>/dev/null || true

  log_files=("$sec_log" "$int_log" "$pat_log" "$mnt_log" "$perf_log")
  [[ -n "$plan_log" ]] && log_files+=("$plan_log")
fi

# ---------------------------------------------------------------------------
# Collect results
# ---------------------------------------------------------------------------
all_tickets_file=$(mktemp)
trap 'rm -f "$all_tickets_file"' EXIT

echo ""
for logfile in "${log_files[@]}"; do
  [[ -f "$logfile" ]] || continue
  label=$(basename "$logfile" .log | sed 's/-[0-9]*$//')

  # Final summary = last assistant text block only (drops mid-process narration).
  final_text=$(jq -rs '[.[] | select(.type == "assistant") | .message.content[]? | select(.type == "text") | .text] | last // ""' "$logfile" 2>/dev/null)
  verdict=$(echo "$final_text" | grep -oE '[A-Z]+_(PASS|ISSUES)' | tail -1)
  summary=$(echo "$final_text" | grep -vE '^[A-Z]+_(PASS|ISSUES)[[:space:]]*$' | sed '/^[[:space:]]*$/d')

  persona_tickets=$(parse_filed_tickets "$logfile")
  fix_count=$(printf '%s\n' "$persona_tickets" | grep -c '^fix	' || true)
  kaizen_count=$(printf '%s\n' "$persona_tickets" | grep -c '^kaizen	' || true)

  if [[ "$verdict" == *"_PASS" ]]; then
    if [[ "$kaizen_count" -gt 0 || "$fix_count" -gt 0 ]]; then
      annot=""
      [[ "$fix_count" -gt 0 ]] && annot="${fix_count} fix"
      [[ "$kaizen_count" -gt 0 ]] && annot="${annot:+$annot, }${kaizen_count} kaizen"
      out "${C_GREEN}✓${C_RESET}" "${label}: pass (${annot} filed)"
    else
      out "${C_GREEN}✓${C_RESET}" "${label}: pass"
    fi
  elif [[ "$verdict" == *"_ISSUES" ]]; then
    annot=""
    [[ "$fix_count" -gt 0 ]] && annot="${fix_count} fix"
    [[ "$kaizen_count" -gt 0 ]] && annot="${annot:+$annot, }${kaizen_count} kaizen"
    [[ -z "$annot" ]] && annot="no tickets parsed"
    out "${C_MAGENTA}●${C_RESET}" "${label}: issues filed (${annot})"
  else
    out "${C_DIM}?${C_RESET}" "${label}: (no verdict)"
  fi

  if [[ -n "$summary" ]]; then
    while IFS= read -r line; do
      detail "⎿ $line"
    done <<< "$summary"
  fi

  if [[ -n "$persona_tickets" ]]; then
    while IFS=$'\t' read -r kind prio id title; do
      [[ -z "$kind" ]] && continue
      if [[ "$kind" == "fix" ]]; then
        detail "⎿ Fix:    ${id} (P${prio}) ${title}"
      else
        detail "⎿ Kaizen: ${id} (P${prio}) ${title}"
      fi
      printf '%s\t%s\t%s\t%s\t%s\n' "$kind" "$prio" "$id" "$label" "$title" >> "$all_tickets_file"
    done <<< "$persona_tickets"
  fi
done

# ---------------------------------------------------------------------------
# Roll-up
# ---------------------------------------------------------------------------
must_fix=$(awk -F'\t' '$1=="fix" && ($2=="1" || $2=="2")' "$all_tickets_file" | wc -l)
should_fix=$(awk -F'\t' '$1=="fix" && $2=="3"' "$all_tickets_file" | wc -l)
other_fix=$(awk -F'\t' '$1=="fix" && $2!="1" && $2!="2" && $2!="3"' "$all_tickets_file" | wc -l)
kaizen_total=$(awk -F'\t' '$1=="kaizen"' "$all_tickets_file" | wc -l)

print_bucket() {
  local label="$1" filter="$2" count="$3"
  detail "${label}: ${count}"
  [[ "$count" -gt 0 ]] || return 0
  awk -F'\t' "${filter} {printf \"      %s  P%s  [%s] %s\\n\", \$3, \$2, \$4, \$5}" "$all_tickets_file" \
    | while IFS= read -r line; do echo -e "    ${C_DIM}${line}${C_RESET}"; done
}

section "Summary"
print_bucket "must-fix (P1-P2)  " '$1=="fix" && ($2=="1" || $2=="2")' "$must_fix"
print_bucket "should-fix (P3)   " '$1=="fix" && $2=="3"'              "$should_fix"
[[ "$other_fix" -gt 0 ]] && \
  print_bucket "other-fix         " '$1=="fix" && $2!="1" && $2!="2" && $2!="3"' "$other_fix"
print_bucket "kaizen (deferrable)" '$1=="kaizen"' "$kaizen_total"

echo ""
deferrable=$((should_fix + other_fix + kaizen_total))
if [[ "$must_fix" -gt 0 ]]; then
  detail "verdict: ${C_RED}blocked${C_RESET} — ${must_fix} P1/P2 fix(es) must land before ship"
elif [[ "$deferrable" -gt 0 ]]; then
  detail "verdict: ${C_GREEN}ship-ready${C_RESET} — no P1/P2 blockers; ${deferrable} deferrable ticket(s) filed"
else
  detail "verdict: ${C_GREEN}clean${C_RESET} — nothing filed"
fi

echo ""
detail "logs: $LOG_DIR/"

if [[ "$must_fix" -gt 0 ]]; then
  exit 1
fi
exit 0
