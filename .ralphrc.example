# .ralphrc.example — copy to .ralphrc and uncomment what you need
#
# Sourced as bash before CLI args are parsed.
# CLI flags override values set here.

# ---------------------------------------------------------------------------
# Loop behavior
# ---------------------------------------------------------------------------
# MAX_ITERATIONS=50        # Total iterations before ralph stops
# MAX_RETRIES=3            # Retries per ticket on Claude failure

# ---------------------------------------------------------------------------
# Model selection
#
# Each agent has a default matched to its cognitive demand:
#   Lead/Spec/Reviewer → opus (planning, judgment, bug detection)
#   Worker             → sonnet (well-specified implementation tasks)
#   Commit/Summary     → haiku (mechanical / low-complexity)
#
# Override individual agents here, or set MODEL to force all agents
# to a single model.
# ---------------------------------------------------------------------------
# LEAD_MODEL="claude-opus-4-6"
# SPEC_MODEL="claude-opus-4-6"
# WORKER_MODEL="claude-sonnet-4-6"
# COMMIT_MODEL="claude-haiku-4-5-20251001"
# REVIEWER_MODEL="claude-opus-4-6"
# SUMMARY_MODEL="claude-haiku-4-5-20251001"
#
# MODEL="claude-sonnet-4-6"   # uncomment to force ALL agents

# ---------------------------------------------------------------------------
# Ticket filters (same as CLI flags)
# ---------------------------------------------------------------------------
# FILTER_TYPE="feature"    # feature | bug | task
# FILTER_PRIORITY=2        # 0=critical, 1=high, 2=medium, 3=low, 4=backlog
# FILTER_OWNER=""
# FILTER_TAG=""

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
# LOG_DIR=".ralph-logs"
# RALPH_RULES_FILE=".ralph-rules.md"

# ---------------------------------------------------------------------------
# ralph-plan — plan refinement pipeline
# ---------------------------------------------------------------------------
# PLAN_REVIEW_ITERATIONS=5
# PLAN_REVIEW_MODEL=""                     # override for all critic/integration/final passes
# PLAN_REVIEW_OUTPUT="PLAN-REFINED.md"
# PLAN_REVIEW_QUESTIONS="PLAN-QUESTIONS.md"
# PLAN_REVIEW_LOG_DIR=".ralph-logs/plan-review"
# PLAN_REVIEW_MAX_RETRIES=3
# PLAN_REVIEW_SPARRING_CMD=""              # single command; use CLI flag for multiple
# PLAN_REVIEW_SPARRING_ITERATIONS=1
# PLAN_REVIEW_SPARRING_TIMEOUT=300         # seconds

# ---------------------------------------------------------------------------
# ralph-babysit — Autonomous PR shepherd
#
# Agent defaults:
#   Triage    → opus (deep code analysis, nuanced judgment)
#   Worker    → sonnet (well-specified implementation)
#   Commit    → haiku (mechanical commit message)
#   CI Worker → sonnet (CI failure diagnosis and fix)
#   Defer     → sonnet (creates Linear issue with context)
# ---------------------------------------------------------------------------
# BABYSIT_INTERVAL=300                    # seconds between polling cycles
# BABYSIT_MAX_CYCLES=0                    # 0 = infinite
# BABYSIT_MAX_RETRIES=3                   # retries per fix group
# BABYSIT_LINEAR_TEAM=""                  # Linear team for deferred issues
# BABYSIT_MAX_CI_CYCLES=3                 # max rounds of CI fix attempts
# BABYSIT_CI_TIMEOUT=600                  # seconds to wait for checks
# TRIAGE_MODEL="claude-opus-4-6"
# BABYSIT_WORKER_MODEL="claude-sonnet-4-6"
# BABYSIT_COMMIT_MODEL="claude-haiku-4-5-20251001"
# BABYSIT_CI_MODEL="claude-sonnet-4-6"
# DEFER_MODEL="claude-sonnet-4-6"

# ---------------------------------------------------------------------------
# Notifications — used by ralph-babysit
# ---------------------------------------------------------------------------
# NOTIFY_TELEGRAM_TOKEN=""                # Bot token from @BotFather
# NOTIFY_TELEGRAM_CHAT_ID=""              # Chat/group ID
# NOTIFY_SLACK_WEBHOOK=""                 # Incoming webhook URL

# ---------------------------------------------------------------------------
# Conditional example — different settings per environment
# ---------------------------------------------------------------------------
# if [[ -n "$CI" ]]; then
#   WORKER_MODEL="claude-opus-4-6"   # cost matters less in CI
#   MAX_RETRIES=5
# fi
